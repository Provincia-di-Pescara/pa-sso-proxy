# ── Dominio pubblico ────────────────────────────────────────────────────────
# Usato da SATOSA per generare redirect URI e SP metadata
PROXY_HOSTNAME=sso.ente.it

# ── Immagini container (registry/tag) ───────────────────────────────────────
# Override opzionali per usare immagini custom complete
# SATOSA_IMAGE=ghcr.io/provincia-di-pescara/pa-sso-proxy-satosa:latest
# CONFIG_API_IMAGE=ghcr.io/provincia-di-pescara/pa-sso-proxy-config-api:latest

# ── Admin WebUI ──────────────────────────────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASSWORD=changeme
SESSION_SECRET=genera-una-stringa-random-di-almeno-32-caratteri

# Rate limiting / protezione brute force per /admin/login
LOGIN_MAX_ATTEMPTS=5
LOGIN_BAN_MINUTES=15
LOGIN_WINDOW_MINUTES=10


# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme

# ── Porta host ───────────────────────────────────────────────────────────────
# Reverse proxy sullo stesso host: 127.0.0.1:18080
# Reverse proxy su host diverso o accesso diretto: 0.0.0.0:18080
PROXY_HOST_PORT=127.0.0.1:18080

# ── SATOSA ───────────────────────────────────────────────────────────────────
# Stringa casuale per hash user ID in SATOSA (genera con: openssl rand -hex 16)
SATOSA_HASH_SALT=genera-una-stringa-random
# Chiave per cifrare il cookie di stato SATOSA (genera con: openssl rand -hex 32)
SATOSA_STATE_ENCRYPTION_KEY=genera-una-stringa-random-di-almeno-32-caratteri

# ── GDPR / Monitoraggio accessi ──────────────────────────────────────────────
# Chiave HMAC-SHA256 per pseudonimizzare il codice fiscale nel log accessi.
# Genera con: openssl rand -hex 32
# Ruotare la chiave = cancellazione effettiva (Art. 17 GDPR)
CF_HASH_KEY=genera-con-openssl-rand-hex-32

# Mesi di retention per i log di accesso individuali (default 24 per obbligo AgID/CAD).
# Dopo questo periodo i record vengono aggregati in access_stats_monthly e cancellati.
# ACCESS_LOG_RETENTION_MONTHS=24

# ── Solo sviluppo locale ──────────────────────────────────────────────────────
# Override BASE SATOSA per test senza DNS/TLS (rimuovi in produzione)
# PROXY_BASE_URL=http://localhost:18080
