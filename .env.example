# ── Dominio pubblico ────────────────────────────────────────────────────────
# Usato da SATOSA per generare redirect URI e SP metadata
PROXY_HOSTNAME=sso.ente.it

# ── Admin WebUI ──────────────────────────────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme

# ── Porta host ───────────────────────────────────────────────────────────────
# Reverse proxy sullo stesso host: 127.0.0.1:18080
# Reverse proxy su host diverso o accesso diretto: 0.0.0.0:18080
PROXY_HOST_PORT=127.0.0.1:18080

# ── Dati ente (Pubblica Amministrazione) ─────────────────────────────────────
ORG_DISPLAY_NAME=Provincia di Pescara
ORG_NAME=Provincia di Pescara
ORG_URL=https://www.provincia.pescara.it
IPA_CODE=P_PE
CONTACT_EMAIL=ict@provincia.pescara.it
CONTACT_PHONE=+3908551234567
ORG_CITY=Pescara
ORG_MUNICIPALITY=068028
