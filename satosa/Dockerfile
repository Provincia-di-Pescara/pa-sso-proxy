FROM ghcr.io/italia/iam-proxy-italia:latest

# Copy CIE OIDC Federation plugin (populate satosa/plugins/ from GovPay before building)
COPY plugins/ /app/plugins/

# Config read from /satosa-conf volume (generated by config-api at startup)
CMD ["gunicorn", \
     "--bind", "0.0.0.0:8080", \
     "--workers", "2", \
     "--timeout", "60", \
     "satosa.wsgi:APP"]
