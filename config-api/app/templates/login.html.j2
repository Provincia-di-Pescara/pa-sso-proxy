<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Login — PA SSO Proxy</title>
  <link rel="stylesheet" href="/admin/static/css/admin.css">
</head>
<body>
<div class="a-login-page">
  <div class="a-login-card">
    {% if s and s.logo_url %}
    <img src="{{ s.logo_url }}" alt="Logo ente" style="height:56px;max-width:160px;object-fit:contain;margin-bottom:12px;">
    {% endif %}
    <div class="a-login-kicker">PA SSO Proxy</div>
    <h1>Accesso amministratore</h1>
    {% if error %}
    <div class="a-alert a-alert-danger">{{ error }}</div>
    {% endif %}
    <form method="post" action="/admin/login">
      <div class="a-form-group">
        <label class="a-label" for="username">Username</label>
        <input type="text" id="username" name="username" class="a-input" autofocus required {% if banned %}disabled{% endif %}>
      </div>
      <div class="a-form-group">
        <label class="a-label" for="password">Password</label>
        <input type="password" id="password" name="password" class="a-input" required {% if banned %}disabled{% endif %}>
      </div>
      <button type="submit" class="a-btn a-btn-primary" style="width:100%;justify-content:center;" {% if banned %}disabled{% endif %}>Accedi</button>
    </form>
  </div>
</div>
</body>
</html>
