{% extends "base.html.j2" %}
{% block title %}{% if client %}Modifica client{% else %}Nuovo client{% endif %} — PA SSO Proxy{% endblock %}
{% block page_title %}{% if client %}Modifica {{ client.name }}{% else %}Nuovo client OIDC{% endif %}{% endblock %}

{% block content %}
{% if error %}<div class="a-alert a-alert-danger">{{ error }}</div>{% endif %}

<div style="max-width:600px;">
  <form method="post">
    <div class="a-form-group">
      <label class="a-label">Nome applicazione</label>
      <input type="text" name="name" class="a-input" required
             value="{{ client.name if client else '' }}">
    </div>

    <div class="a-form-group">
      <label class="a-label">Redirect URI <span style="font-weight:400;text-transform:none;font-size:11px;color:var(--fg-muted);">(una per riga)</span></label>
      <textarea name="redirect_uris" class="a-textarea" rows="3" required>{{ client.redirect_uris | join('\n') if client else '' }}</textarea>
    </div>

    <div class="a-form-group">
      <label class="a-label">Scopes</label>
      <div class="a-check-group">
        {% set current_scopes = client.allowed_scopes if client else ['openid'] %}
        {% for scope in ['openid', 'profile', 'email'] %}
        <label class="a-check-chip {% if scope in current_scopes %}selected{% endif %}">
          <input type="checkbox" name="scopes" value="{{ scope }}"
                 {% if scope in current_scopes %}checked{% endif %}
                 onchange="this.closest('.a-check-chip').classList.toggle('selected', this.checked)">
          {{ scope }}
        </label>
        {% endfor %}
      </div>
    </div>

    {% if client %}
    <div class="a-form-group" style="display:flex;align-items:center;gap:10px;">
      <label class="a-toggle">
        <input type="checkbox" name="enabled" value="1" {% if client.enabled %}checked{% endif %}>
        <span class="a-toggle-slider"></span>
      </label>
      <span style="font-size:13px;color:var(--fg-2);">Abilitato</span>
    </div>
    {% endif %}

    <div style="display:flex;gap:10px;margin-top:24px;">
      <button type="submit" class="a-btn a-btn-primary">Salva</button>
      <a href="/admin/clients" class="a-btn a-btn-secondary">Annulla</a>
    </div>
  </form>

  {% if client and proxy_hostname %}
  <div class="a-card" style="margin-top:24px;">
    <div class="a-card-header">Endpoint OIDC del proxy</div>
    <div class="a-card-body" style="font-size:13px;">
      <div style="margin-bottom:10px;"><strong>Discovery:</strong><br>
        <code class="a-mono">https://{{ proxy_hostname }}/OIDC/.well-known/openid-configuration</code></div>
      <div style="margin-bottom:10px;"><strong>Authorization:</strong><br>
        <code class="a-mono">https://{{ proxy_hostname }}/OIDC/authorization</code></div>
      <div style="margin-bottom:10px;"><strong>Token:</strong><br>
        <code class="a-mono">https://{{ proxy_hostname }}/OIDC/token</code></div>
      <div><strong>Logout (end_session):</strong><br>
        <code class="a-mono">https://{{ proxy_hostname }}/OIDC/end_session</code><br>
        <span class="a-muted" style="font-size:12px;">Parametri: <code>post_logout_redirect_uri</code> (obbligatorio), <code>id_token_hint</code> (consigliato)</span></div>
    </div>
  </div>
  {% endif %}
</div>
{% endblock %}
