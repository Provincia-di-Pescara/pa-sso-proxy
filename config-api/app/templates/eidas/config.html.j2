{% extends "base.html.j2" %}
{% block title %}Configurazione eIDAS — PA SSO Proxy{% endblock %}
{% block page_title %}eIDAS{% endblock %}

{% block content %}
<div style="max-width:720px;">
  {% if request.query_params.get('saved') %}
  <div class="a-alert a-alert-success" style="margin-bottom:16px;">Configurazione eIDAS aggiornata. SATOSA ricaricato.</div>
  {% endif %}

  <div class="a-card" style="margin-bottom:14px;">
    <div class="a-card-header">
      Integrazione eIDAS
      {% if s and s.eidas_enabled %}
      <span class="a-badge a-badge-success">abilitato</span>
      {% else %}
      <span class="a-badge a-badge-neutral">disabilitato</span>
      {% endif %}
    </div>
    <div class="a-card-body">
      <p style="font-size:13px;margin-bottom:20px;color:var(--fg-muted);">
        Permette l'autenticazione di cittadini europei tramite il Nodo eIDAS Italiano (FICEP / AgID).
      </p>

      <form method="post" action="/admin/eidas/toggle" id="eidas-form" onsubmit="return handleSubmit(event)">
        <input type="hidden" name="confirmed" id="eidas-confirmed" value="no">

        <div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;">
          <label class="a-toggle">
            <input type="checkbox" name="eidas_enabled" id="eidas-enabled" value="yes" {% if s and s.eidas_enabled %}checked{% endif %}>
            <span class="a-toggle-slider"></span>
          </label>
          <span style="font-weight:600;font-size:14px;color:var(--fg-1);user-select:none;">Abilita Integrazione eIDAS</span>
        </div>

        <div class="a-form-group">
          <label class="a-label" for="eidas-env">Ambiente di esercizio</label>
          <select name="environment" id="eidas-env" class="a-select" style="max-width:300px;">
            <option value="prod" {% if s and s.eidas_environment == 'prod' %}selected{% endif %}>Produzione (PROD)</option>
            <option value="qa" {% if s and s.eidas_environment == 'qa' %}selected{% endif %}>Pre-produzione (QA)</option>
          </select>
          <div class="a-form-hint">Seleziona l'ambiente del gateway eIDAS italiano gestito da AgID.</div>
        </div>

        <div style="margin-top:24px;">
          <button type="submit" class="a-btn a-btn-primary">Salva configurazione</button>
        </div>
      </form>
    </div>
  </div>

  {# Certificate section #}
  <div class="a-card" style="margin-bottom:14px;">
    <div class="a-card-header">
      Certificato di Firma SPID / eIDAS (SAML SP)
      <span class="a-badge a-badge-neutral">Certificato</span>
    </div>
    <div class="a-card-body">
      {% if cert_error %}<div class="a-alert a-alert-danger">{{ cert_error }}</div>{% endif %}
      {% if s and s.eidas_enabled and metadata_status and not metadata_status.has_eidas %}
        <div class="a-alert a-alert-warning" style="margin-bottom:16px;">
          <strong>Attenzione:</strong> eIDAS è abilitato in configurazione, ma il metadata pubblicato non supporta ancora eIDAS (indici FICEP 99/100 mancanti).
          Rigenera il certificato di firma per pubblicare il metadata conforme a eIDAS.
        </div>
      {% endif %}
      {% if cert %}
        {% set days_left = (cert.not_valid_after - now).days %}
        {% if days_left < 30 %}
          <div class="a-alert a-alert-danger">Il certificato scade tra <strong>{{ days_left }} giorni</strong> ({{ cert.not_valid_after.strftime('%Y-%m-%d') }}).</div>
        {% elif days_left < 90 %}
          <div class="a-alert a-alert-warning">Il certificato scade tra <strong>{{ days_left }} giorni</strong> ({{ cert.not_valid_after.strftime('%Y-%m-%d') }}).</div>
        {% else %}
          <div class="a-alert a-alert-success">Certificato valido fino al <strong>{{ cert.not_valid_after.strftime('%Y-%m-%d') }}</strong> ({{ days_left }} giorni).</div>
        {% endif %}
        <div class="a-form-group">
          <label class="a-label">Subject DN</label>
          <input class="a-input a-input-ro" type="text" value="{{ cert.subject_dn }}" readonly>
        </div>
        <div class="a-muted" style="font-size:12px;margin-bottom:16px;">Generato il: <span class="a-mono">{{ cert.created_at.strftime('%Y-%m-%d %H:%M') }}</span></div>
        <form method="post" action="/admin/certs/generate?redirect_to=/admin/eidas" onsubmit="return confirmRegenCert()">
          <button type="submit" class="a-btn a-btn-secondary a-btn-sm">Rigenera certificato</button>
        </form>
      {% else %}
        <div class="a-alert a-alert-warning" style="margin-bottom:16px;">Nessun certificato SPID / eIDAS configurato. Genera il certificato per abilitare l'autenticazione.</div>
        <form method="post" action="/admin/certs/generate?redirect_to=/admin/eidas">
          <button type="submit" class="a-btn a-btn-primary">Genera certificato</button>
        </form>
      {% endif %}
    </div>
  </div>

  {# SAML SP Metadata Status Card #}
  <div class="a-card" style="margin-bottom:14px;">
    <div class="a-card-header">
      Stato Metadata SAML (Service Provider)
      <span class="a-badge a-badge-neutral">SAML SP</span>
    </div>
    <div class="a-card-body">
      <p style="font-size:13px;margin-bottom:12px;color:var(--fg-muted);">
        Il proxy pubblica il proprio metadata SAML a questo URL pubblico, necessario per registrare il servizio presso AgID/IdP:
      </p>
      <div class="a-form-group" style="margin-bottom:12px;">
        <input class="a-input a-input-ro a-mono" type="text" value="https://{{ proxy_hostname }}/spidSaml2/metadata" readonly style="font-size:12px;">
      </div>
      
      {% if metadata_status %}
        {% if metadata_status.valid %}
          <div style="display:flex;flex-direction:column;gap:10px;margin-top:8px;">
            <div style="display:flex;align-items:center;gap:8px;">
              <span style="font-size:13px;font-weight:600;color:var(--fg-muted);">Supporto SPID:</span>
              {% if metadata_status.has_spid %}
                <span class="a-badge a-badge-success">Attivo</span>
              {% else %}
                <span class="a-badge a-badge-danger">Non configurato</span>
              {% endif %}
            </div>
            <div style="display:flex;align-items:center;gap:8px;">
              <span style="font-size:13px;font-weight:600;color:var(--fg-muted);">Supporto eIDAS (FICEP):</span>
              {% if metadata_status.has_eidas %}
                <span class="a-badge a-badge-success">Attivo (indici 99/100 presenti)</span>
              {% else %}
                <span class="a-badge a-badge-neutral">Non attivo</span>
              {% endif %}
            </div>
          </div>
          {% if s and s.eidas_enabled and not metadata_status.has_eidas %}
            <div class="a-alert a-alert-warning" style="margin-top:14px;">
              <strong>Attenzione:</strong> eIDAS è abilitato in configurazione, ma il metadata pubblicato non contiene gli indici FICEP (99/100). 
              Verifica che SATOSA sia stato ricaricato correttamente.
            </div>
          {% endif %}
        {% else %}
          <div class="a-alert a-alert-danger" style="margin-top:8px;">
            <strong>Impossibile verificare lo stato del metadata locale:</strong> {{ metadata_status.error }}
          </div>
        {% endif %}
      {% else %}
        <div class="a-muted" style="font-size:12px;">Verifica in corso...</div>
      {% endif %}
    </div>
  </div>
</div>

<script>
const initialEnabled = {% if s and s.eidas_enabled %}true{% else %}false{% endif %};

function handleSubmit(event) {
  var isEnabled = document.getElementById("eidas-enabled").checked;
  var envSelect = document.getElementById("eidas-env");
  var envLabel = envSelect.options[envSelect.selectedIndex].text;
  var confirmedInput = document.getElementById("eidas-confirmed");
  
  if (isEnabled && !initialEnabled) {
    var ok = window.confirm(
      "Abilitare l'integrazione eIDAS in ambiente " + envLabel + "?\n\n" +
      "Questo renderà visibile il pulsante di login eIDAS sulla pagina di scelta provider."
    );
    if (!ok) {
      event.preventDefault();
      return false;
    }
    confirmedInput.value = "yes";
  } else if (!isEnabled && initialEnabled) {
    var ok = window.confirm(
      "Disabilitare l'integrazione eIDAS?\n\n" +
      "Questo nasconderà il pulsante di login eIDAS dalla pagina di scelta provider."
    );
    if (!ok) {
      event.preventDefault();
      return false;
    }
    confirmedInput.value = "yes";
  } else {
    confirmedInput.value = "yes";
  }
  return true;
}

function confirmRegenCert() {
  return window.confirm(
    "ATTENZIONE: La rigenerazione del certificato genererà una nuova chiave privata e un nuovo certificato di firma.\n\n" +
    "Questo invaliderà immediatamente il metadata SAML precedentemente registrato su AgID/FICEP e renderà impossibile l'autenticazione fino all'aggiornamento dei portali governativi.\n\n" +
    "Vuoi procedere?"
  );
}
</script>
{% endblock %}
