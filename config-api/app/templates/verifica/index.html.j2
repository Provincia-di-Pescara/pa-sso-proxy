<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Verifica SPID{% if settings and settings.org_display_name %} — {{ settings.org_display_name }}{% endif %}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Titillium Web', Arial, sans-serif; background: #f5f5f5; color: #17324d; min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 24px; }
    .card { background: #fff; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,.12); padding: 40px 48px; max-width: 480px; width: 100%; }
    .logo { display: flex; align-items: center; gap: 12px; margin-bottom: 28px; }
    .logo svg { width: 48px; height: 48px; }
    .logo-text { font-size: 20px; font-weight: 700; color: #0066cc; }
    h1 { font-size: 22px; font-weight: 700; margin-bottom: 8px; }
    .subtitle { font-size: 14px; color: #5c6f82; margin-bottom: 28px; line-height: 1.5; }
    .levels { display: flex; gap: 12px; margin-bottom: 24px; }
    .levels label { display: flex; align-items: center; gap: 6px; font-size: 14px; cursor: pointer; padding: 8px 14px; border: 1.5px solid #ccd4dc; border-radius: 6px; flex: 1; justify-content: center; transition: border-color .15s, background .15s; }
    .levels label:has(input:checked) { border-color: #0066cc; background: #e8f1fb; font-weight: 600; }
    .btn-spid { display: inline-flex; align-items: center; justify-content: center; gap: 10px; background: #0066cc; color: #fff; border: none; border-radius: 6px; padding: 14px 28px; font-size: 16px; font-weight: 700; cursor: pointer; width: 100%; text-decoration: none; transition: background .15s; }
    .btn-spid:hover { background: #004c99; }
    .btn-spid svg { width: 24px; height: 24px; fill: #fff; }
    .note { font-size: 12px; color: #5c6f82; margin-top: 20px; line-height: 1.5; border-top: 1px solid #eee; padding-top: 16px; }
    .badge { display: inline-block; background: #e8f1fb; color: #0066cc; border-radius: 4px; padding: 2px 8px; font-size: 12px; font-weight: 600; margin-bottom: 16px; }
  </style>
</head>
<body>
  <div class="card">
    <div class="logo">
      <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect width="48" height="48" rx="8" fill="#0066cc"/>
        <path d="M24 12C17.373 12 12 17.373 12 24s5.373 12 12 12 12-5.373 12-12-5.373-12-12-12zm-1 17v-6h2v6h-2zm0-8v-2h2v2h-2z" fill="#fff"/>
      </svg>
      <span class="logo-text">PA SSO Proxy</span>
    </div>

    <span class="badge">Ambiente di test</span>

    <h1>Verifica integrazione SPID</h1>
    <p class="subtitle">
      Pagina di test per la validazione del metadata SPID presso AgID.
      {% if settings and settings.org_display_name %}Ente: <strong>{{ settings.org_display_name }}</strong>.{% endif %}
    </p>

    <form method="get" action="/verifica/start">
      <div class="levels">
        {% for lvl, label in [('1','L1 — Minimo'), ('2','L2 — Standard'), ('3','L3 — Massimo')] %}
        <label>
          <input type="radio" name="level" value="{{ lvl }}" {% if lvl == '2' %}checked{% endif %} style="accent-color:#0066cc;">
          {{ label }}
        </label>
        {% endfor %}
      </div>
      <button type="submit" class="btn-spid">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2a5 5 0 1 1 0 10A5 5 0 0 1 12 2zm0 12c5.33 0 8 2.67 8 4v2H4v-2c0-1.33 2.67-4 8-4z"/></svg>
        Entra con SPID
      </button>
    </form>

    <p class="note">
      Provider attivo: <strong>{{ test_idp_name }}</strong>.<br>
      Questa pagina è disponibile solo quando è abilitato un IdP di test (validator o demo).
    </p>
  </div>
</body>
</html>
