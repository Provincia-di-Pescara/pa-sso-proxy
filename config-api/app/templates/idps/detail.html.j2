{% extends "base.html.j2" %}
{% block title %}Dettaglio metadata SPID — PA SSO Proxy{% endblock %}
{% block page_title %}Dettaglio metadata SPID{% endblock %}
{% block page_subtitle %}<div class="a-topbar-sub">Vista live del singolo metadata dal registry AgID</div>{% endblock %}

{% block topbar_actions %}
<a href="/admin/idps" class="a-btn a-btn-secondary a-btn-sm">← Torna alla lista</a>
{% endblock %}

{% block content %}
{% if detail_call.ok %}
<div class="a-card" style="margin-bottom:14px;">
  <div class="a-card-body" style="display:grid;grid-template-columns:1fr auto auto auto;gap:20px;align-items:start;">
    <div>
      <div class="a-label">Endpoint</div>
      <code class="a-mono" style="font-size:11px;word-break:break-all;">{{ detail_call.request_url }}</code>
    </div>
    <div>
      <div class="a-label">Tot metadata</div>
      <div style="font-size:14px;">{{ detail_call.headers.tot_metadata or '—' }}</div>
    </div>
    <div>
      <div class="a-label">Pagina</div>
      <div style="font-size:14px;">{{ detail_call.headers.current_page or '—' }}</div>
    </div>
    <div>
      <div class="a-label">Last modified</div>
      <div class="a-mono" style="font-size:11px;">{{ detail_call.headers.last_modified or '—' }}</div>
    </div>
  </div>
</div>

<div class="a-card" style="margin-bottom:14px;">
  <div class="a-card-header">Campi principali</div>
  <div class="a-table-wrap">
    <table class="a-table">
      <tbody>
        {% set summary_keys = [
          ('entity_id', 'Entity ID'),
          ('organization_display_name', 'Organization display name'),
          ('organization_name', 'Organization name'),
          ('code', 'Code'),
          ('create_date', 'Create date'),
          ('lastupdate_date', 'Last update date'),
          ('delete_date', 'Delete date'),
          ('_disabled', 'Disabled'),
          ('_deleted', 'Deleted'),
          ('registry_link', 'Registry link')
        ] %}
        {% for key, label in summary_keys %}
        {% if detail_call.detail.get(key) is not none %}
        <tr>
          <td style="width:240px;font-weight:600;font-size:12px;white-space:nowrap;color:var(--fg-muted);">{{ label }}</td>
          <td>
            {% set value = detail_call.detail.get(key) %}
            {% if value is mapping or (value is sequence and value is not string) %}
              <pre style="margin:0;font-size:11px;background:var(--bg-1);padding:8px;border-radius:4px;overflow-x:auto;">{{ value | tojson(indent=2) }}</pre>
            {% else %}
              <span class="a-mono" style="font-size:12px;">{{ value }}</span>
            {% endif %}
          </td>
        </tr>
        {% endif %}
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>

<div class="a-card">
  <div class="a-card-header">Tutti i campi</div>
  <div class="a-table-wrap">
    <table class="a-table">
      <tbody>
        {% for key, value in detail_call.detail.items() %}
        <tr>
          <td style="width:240px;font-weight:600;font-size:12px;white-space:nowrap;color:var(--fg-muted);">{{ key }}</td>
          <td>
            {% if value is mapping or (value is sequence and value is not string) %}
              <pre style="margin:0;font-size:11px;background:var(--bg-1);padding:8px;border-radius:4px;overflow-x:auto;">{{ value | tojson(indent=2) }}</pre>
            {% elif value is none %}
              <span class="a-muted">—</span>
            {% else %}
              <span class="a-mono" style="font-size:12px;">{{ value }}</span>
            {% endif %}
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>

{% else %}
<div class="a-alert a-alert-warning">Impossibile recuperare il metadata live: {{ detail_call.error }}</div>
{% endif %}
{% endblock %}
