{% extends "base.html.j2" %}
{% block title %}Provider SPID — PA SSO Proxy{% endblock %}
{% block content %}
<div class="d-flex justify-content-between align-items-center mb-3">
  <h2>Provider SPID</h2>
  <div class="d-flex gap-2 align-items-center">
    {% if proxy_hostname %}
    <a href="https://{{ proxy_hostname }}/spidSaml2/metadata" target="_blank" class="btn btn-sm btn-outline-secondary">
      📄 Metadata SP (AgID)
    </a>
    {% endif %}
    <form method="post" action="/admin/idps/sync" class="d-inline">
      <button class="btn btn-sm btn-primary">Sync manuale da Registry</button>
    </form>
  </div>
</div>

<div class="card mb-4 border-primary">
  <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
    <h5 class="mb-0">Ambiente di Test / Validazione</h5>
    <span class="badge bg-light text-primary">SPID SAML</span>
  </div>
  <div class="card-body">
    <p class="text-muted mb-4">
      Attiva uno dei provider di test/validazione per effettuare l'integrazione o il collaudo del proxy. 
      <strong>Solo un provider alla volta può essere attivo.</strong> L'attivazione di uno disabiliterà automaticamente l'altro.
    </p>
    
    <div class="row g-4">
      <!-- Demo Provider Card -->
      <div class="col-md-6">
        <div class="p-3 border rounded h-100 d-flex flex-column justify-content-between {% if demo_idp and demo_idp.enabled %}border-success bg-success bg-opacity-10{% endif %}" style="transition: all 0.2s ease;">
          <div>
            <div class="d-flex align-items-center justify-content-between mb-2">
              <h6 class="mb-0">SPID Demo Provider</h6>
              {% if demo_idp and demo_idp.enabled %}
                <span class="badge bg-success">Attivo</span>
              {% else %}
                <span class="badge bg-secondary">Inattivo</span>
              {% endif %}
            </div>
            <p class="small text-muted mb-3">
              Permette l'autenticazione tramite il provider di demo ufficiale di SPID (per simulare cittadini ed effettuare collaudi).
            </p>
            <code class="d-block small text-break mb-3">{{ demo_idp.metadata_url if demo_idp else 'https://demo.spid.gov.it/metadata.xml' }}</code>
          </div>
          <div>
            {% if demo_idp %}
            <form method="post" action="/admin/idps/{{ demo_idp.id }}/toggle">
              <button type="submit" class="btn btn-sm w-100 {% if demo_idp.enabled %}btn-outline-danger{% else %}btn-success{% endif %}">
                {% if demo_idp.enabled %}Disattiva Demo{% else %}Attiva Demo{% endif %}
              </button>
            </form>
            {% else %}
            <button class="btn btn-sm btn-secondary w-100" disabled>In caricamento...</button>
            {% endif %}
          </div>
        </div>
      </div>
      
      <!-- Validator Card -->
      <div class="col-md-6">
        <div class="p-3 border rounded h-100 d-flex flex-column justify-content-between {% if validator_idp and validator_idp.enabled %}border-success bg-success bg-opacity-10{% endif %}" style="transition: all 0.2s ease;">
          <div>
            <div class="d-flex align-items-center justify-content-between mb-2">
              <h6 class="mb-0">Validator AgID</h6>
              {% if validator_idp and validator_idp.enabled %}
                <span class="badge bg-success">Attivo</span>
              {% else %}
                <span class="badge bg-secondary">Inattivo</span>
              {% endif %}
            </div>
            <p class="small text-muted mb-3">
              Permette di verificare la conformità del proxy inviando le richieste di autenticazione al validatore ufficiale di AgID.
            </p>
            <code class="d-block small text-break mb-3">{{ validator_idp.metadata_url if validator_idp else 'https://validator.spid.gov.it/metadata.xml' }}</code>
          </div>
          <div>
            {% if validator_idp %}
            <form method="post" action="/admin/idps/{{ validator_idp.id }}/toggle">
              <button type="submit" class="btn btn-sm w-100 {% if validator_idp.enabled %}btn-outline-danger{% else %}btn-success{% endif %}">
                {% if validator_idp.enabled %}Disattiva Validatore{% else %}Attiva Validatore{% endif %}
              </button>
            </form>
            {% else %}
            <button class="btn btn-sm btn-secondary w-100" disabled>In caricamento...</button>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="card mb-4">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-3">
      <div>
        <h5 class="card-title mb-1">Aggiorna metadata SPID Registry</h5>
        <p class="text-muted mb-0">Lista locale sincronizzata giornalmente dal registry AgID.</p>
      </div>
      <div class="text-end">
        <div class="small text-muted">Ultima sync DB</div>
        <div><small>{{ last_sync_at.strftime('%d/%m/%Y %H:%M') if last_sync_at else '—' }}</small></div>
      </div>
    </div>

    {% if sync_status == 'ok' %}
    <div class="alert alert-success py-2">
      Sync completata. Nuovi IdP inseriti: {{ sync_inserted or '0' }}.
    </div>
    {% elif sync_status == 'error' %}
    <div class="alert alert-warning py-2">
      Sync non riuscita ({{ sync_error or 'errore sconosciuto' }}).
    </div>
    {% endif %}

    {% if idps %}
    <div class="table-responsive">
      <table class="table table-sm table-hover align-middle mb-0">
        <thead>
          <tr>
            <th>Logo</th>
            <th>Entity ID</th>
            <th>Organization name</th>
            <th>Last update date</th>
            <th>Abilitato</th>
            <th>Dettagli</th>
          </tr>
        </thead>
        <tbody>
          {% for item in idps %}
          <tr>
            <td style="width: 72px;">
              {% if item.registry_logo_uri %}
              <img src="{{ item.registry_logo_uri }}" alt="Logo {{ item.registry_organization_name or item.registry_entity_id }}" style="max-height: 32px; max-width: 64px; object-fit: contain;">
              {% else %}
              <span class="text-muted">—</span>
              {% endif %}
            </td>
            <td><code class="text-break">{{ item.registry_entity_id or '—' }}</code></td>
            <td>{{ item.registry_organization_name or item.display_name or '—' }}</td>
            <td><small>{{ item.registry_lastupdate_date or '—' }}</small></td>
            <td>
              <form method="post" action="/admin/idps/{{ item.id }}/toggle" class="d-inline">
                {% if item.enabled %}
                <button type="submit" class="btn btn-sm btn-success" title="Clicca per disabilitare">✓ Sì</button>
                {% else %}
                <button type="submit" class="btn btn-sm btn-outline-secondary" title="Clicca per abilitare">No</button>
                {% endif %}
              </form>
            </td>
            <td>
              <a class="btn btn-sm btn-outline-primary" href="/admin/idps/detail?entity_id={{ item.registry_entity_id | urlencode }}">Dettagli</a>
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    {% else %}
    <p class="text-muted mb-0">Nessun IdP sincronizzato dal registry.</p>
    {% endif %}
  </div>
</div>
{% endblock %}
