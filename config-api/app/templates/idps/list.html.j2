{% extends "base.html.j2" %}
{% block title %}Provider SPID — PA SSO Proxy{% endblock %}
{% block content %}
<div class="d-flex justify-content-between align-items-center mb-3">
  <h2>Provider SPID</h2>
</div>
{% if idps %}
<table class="table table-sm table-hover">
  <thead>
    <tr>
      <th>Nome</th>
      <th>Alias</th>
      <th>URL Metadata</th>
      <th>Stato</th>
      <th>Ultimo aggiornamento</th>
      <th>Azioni</th>
    </tr>
  </thead>
  <tbody>
    {% for idp in idps %}
    <tr>
      <td>{{ idp.display_name }}</td>
      <td><code>{{ idp.alias }}</code></td>
      <td><small>{{ idp.metadata_url[:60] }}{% if idp.metadata_url|length > 60 %}…{% endif %}</small></td>
      <td>
        {% if idp.enabled %}<span class="badge bg-success">Abilitato</span>
        {% else %}<span class="badge bg-secondary">Disabilitato</span>{% endif %}
        {% if idp.metadata_cache %}<span class="badge bg-info ms-1">Cache OK</span>
        {% else %}<span class="badge bg-warning ms-1">Cache assente</span>{% endif %}
      </td>
      <td>
        {% if idp.last_updated %}
          <small>{{ idp.last_updated.strftime('%d/%m/%Y %H:%M') }}</small>
        {% else %}
          <small class="text-muted">—</small>
        {% endif %}
      </td>
      <td>
        <form method="post" action="/admin/idps/{{ idp.id }}/toggle" class="d-inline">
          <button class="btn btn-sm btn-outline-warning">
            {% if idp.enabled %}Disabilita{% else %}Abilita{% endif %}
          </button>
        </form>
        <form method="post" action="/admin/idps/{{ idp.id }}/refresh" class="d-inline">
          <button class="btn btn-sm btn-outline-primary">Aggiorna metadata</button>
        </form>
      </td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% else %}
<p class="text-muted">Nessun provider SPID configurato.</p>
{% endif %}
{% endblock %}
