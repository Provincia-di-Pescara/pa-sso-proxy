{% extends "base.html.j2" %}
{% block title %}Provider SPID — PA SSO Proxy{% endblock %}
{% block page_title %}Provider SPID{% endblock %}

{% block topbar_actions %}
<div style="display:flex;gap:8px;align-items:center;">
  {% if proxy_hostname %}
  <a href="https://{{ proxy_hostname }}/spidSaml2/metadata" target="_blank" class="a-btn a-btn-secondary a-btn-sm">Metadata SP (AgID)</a>
  {% endif %}
  <form method="post" action="/admin/idps/enable-all" style="display:inline;">
    <button class="a-btn a-btn-neutral a-btn-sm">Abilita tutti</button>
  </form>
  <form method="post" action="/admin/idps/sync" style="display:inline;">
    <button class="a-btn a-btn-primary a-btn-sm">Sync da Registry</button>
  </form>
</div>
{% endblock %}

{% block content %}
{# Test/Validation providers #}
<div class="a-card" style="margin-bottom:14px;">
  <div class="a-card-header">
    Ambiente di Test / Validazione
    <span class="a-badge-spid">SPID SAML</span>
  </div>
  <div class="a-card-body">
    <div class="a-muted" style="margin-bottom:16px;font-size:13px;">
      Attiva uno dei provider di test/validazione per effettuare l'integrazione o il collaudo del proxy.
      <strong>Solo un provider alla volta può essere attivo.</strong>
    </div>
    <div class="a-grid-2">
      {# Demo Provider #}
      <div class="a-card" style="{% if demo_idp and demo_idp.enabled %}border-color: var(--success);{% endif %}">
        <div class="a-card-header">
          SPID Demo Provider
          {% if demo_idp and demo_idp.enabled %}
            <span class="a-badge a-badge-success">Attivo</span>
          {% else %}
            <span class="a-badge a-badge-neutral">Inattivo</span>
          {% endif %}
        </div>
        <div class="a-card-body">
          <p style="font-size:13px;color:var(--fg-muted);margin-bottom:12px;">Permette l'autenticazione tramite il provider di demo ufficiale di SPID.</p>
          <code class="a-mono" style="display:block;word-break:break-all;font-size:11px;margin-bottom:16px;">{{ demo_idp.metadata_url if demo_idp else 'https://demo.spid.gov.it/metadata.xml' }}</code>
          {% if demo_idp %}
          <form method="post" action="/admin/idps/{{ demo_idp.id }}/toggle">
            <button type="submit" class="a-btn {% if demo_idp.enabled %}a-btn-danger{% else %}a-btn-primary{% endif %} a-btn-sm" style="width:100%;justify-content:center;">
              {% if demo_idp.enabled %}Disattiva Demo{% else %}Attiva Demo{% endif %}
            </button>
          </form>
          {% if demo_idp.enabled %}
          <div style="margin-top: 12px; text-align: center;">
            <a href="/verifica" target="_blank" style="font-size: 12px; font-weight: 600; color: #0056b3; text-decoration: underline;">Apri Pagina di Verifica &rarr;</a>
          </div>
          {% endif %}
          {% else %}
          <button class="a-btn a-btn-neutral a-btn-sm" style="width:100%;" disabled>In caricamento...</button>
          {% endif %}
        </div>
      </div>

      {# Validator #}
      <div class="a-card" style="{% if validator_idp and validator_idp.enabled %}border-color: var(--success);{% endif %}">
        <div class="a-card-header">
          Validator AgID
          {% if validator_idp and validator_idp.enabled %}
            <span class="a-badge a-badge-success">Attivo</span>
          {% else %}
            <span class="a-badge a-badge-neutral">Inattivo</span>
          {% endif %}
        </div>
        <div class="a-card-body">
          <p style="font-size:13px;color:var(--fg-muted);margin-bottom:12px;">Permette di verificare la conformità del proxy tramite il validatore ufficiale di AgID.</p>
          <code class="a-mono" style="display:block;word-break:break-all;font-size:11px;margin-bottom:16px;">{{ validator_idp.metadata_url if validator_idp else 'https://validator.spid.gov.it/metadata.xml' }}</code>
          {% if validator_idp %}
          <form method="post" action="/admin/idps/{{ validator_idp.id }}/toggle">
            <button type="submit" class="a-btn {% if validator_idp.enabled %}a-btn-danger{% else %}a-btn-primary{% endif %} a-btn-sm" style="width:100%;justify-content:center;">
              {% if validator_idp.enabled %}Disattiva Validatore{% else %}Attiva Validatore{% endif %}
            </button>
          </form>
          {% if validator_idp.enabled %}
          <div style="margin-top: 12px; text-align: center;">
            <a href="/verifica" target="_blank" style="font-size: 12px; font-weight: 600; color: #0056b3; text-decoration: underline;">Apri Pagina di Verifica &rarr;</a>
          </div>
          {% endif %}
          {% else %}
          <button class="a-btn a-btn-neutral a-btn-sm" style="width:100%;" disabled>In caricamento...</button>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</div>

{# Certificate section #}
<div class="a-card" style="margin-bottom:14px;">
  <div class="a-card-header">
    Certificato di Firma SPID (SAML SP)
    <span class="a-badge a-badge-neutral">Certificato</span>
  </div>
  <div class="a-card-body">
    {% if cert_error %}<div class="a-alert a-alert-danger">{{ cert_error }}</div>{% endif %}
    {% if s and s.eidas_enabled and metadata_status and not metadata_status.has_eidas %}
      <div class="a-alert a-alert-warning" style="margin-bottom:16px;">
        <strong>Attenzione:</strong> eIDAS è abilitato in configurazione, ma il metadata pubblicato non supporta ancora eIDAS (indici FICEP 99/100 mancanti).
        Rigenera il certificato di firma per pubblicare il metadata conforme a eIDAS.
      </div>
    {% endif %}
    {% if cert %}
      {% set days_left = (cert.not_valid_after - now).days %}
      {% if days_left < 30 %}
        <div class="a-alert a-alert-danger">Il certificato scade tra <strong>{{ days_left }} giorni</strong> ({{ cert.not_valid_after.strftime('%Y-%m-%d') }}).</div>
      {% elif days_left < 90 %}
        <div class="a-alert a-alert-warning">Il certificato scade tra <strong>{{ days_left }} giorni</strong> ({{ cert.not_valid_after.strftime('%Y-%m-%d') }}).</div>
      {% else %}
        <div class="a-alert a-alert-success">Certificato valido fino al <strong>{{ cert.not_valid_after.strftime('%Y-%m-%d') }}</strong> ({{ days_left }} giorni).</div>
      {% endif %}
      <div class="a-form-group">
        <label class="a-label">Subject DN</label>
        <input class="a-input a-input-ro" type="text" value="{{ cert.subject_dn }}" readonly>
      </div>
      <div class="a-muted" style="font-size:12px;margin-bottom:16px;">Generato il: <span class="a-mono">{{ cert.created_at.strftime('%Y-%m-%d %H:%M') }}</span></div>
      <form method="post" action="/admin/certs/generate" onsubmit="return confirmRegenCert()">
        <button type="submit" class="a-btn a-btn-secondary a-btn-sm">Rigenera certificato</button>
      </form>
    {% else %}
      <div class="a-alert a-alert-warning" style="margin-bottom:16px;">Nessun certificato SPID configurato. Genera il certificato per abilitare l'autenticazione SPID.</div>
      <form method="post" action="/admin/certs/generate">
        <button type="submit" class="a-btn a-btn-primary">Genera certificato</button>
      </form>
    {% endif %}
  </div>
</div>

{# SAML SP Metadata Status Card #}
<div class="a-card" style="margin-bottom:14px;">
  <div class="a-card-header">
    Stato Metadata SAML (Service Provider)
    <span class="a-badge a-badge-neutral">SAML SP</span>
  </div>
  <div class="a-card-body">
    <p style="font-size:13px;margin-bottom:12px;color:var(--fg-muted);">
      Il proxy pubblica il proprio metadata SAML a questo URL pubblico, necessario per registrare il servizio presso AgID/IdP:
    </p>
    <div class="a-form-group" style="margin-bottom:12px;">
      <input class="a-input a-input-ro a-mono" type="text" value="https://{{ proxy_hostname }}/spidSaml2/metadata" readonly style="font-size:12px;">
    </div>
    
    {% if metadata_status %}
      {% if metadata_status.valid %}
        <div style="display:flex;flex-direction:column;gap:10px;margin-top:8px;">
          <div style="display:flex;align-items:center;gap:8px;">
            <span style="font-size:13px;font-weight:600;color:var(--fg-muted);">Supporto SPID:</span>
            {% if metadata_status.has_spid %}
              <span class="a-badge a-badge-success">Attivo</span>
            {% else %}
              <span class="a-badge a-badge-danger">Non configurato</span>
            {% endif %}
          </div>
          <div style="display:flex;align-items:center;gap:8px;">
            <span style="font-size:13px;font-weight:600;color:var(--fg-muted);">Supporto eIDAS (FICEP):</span>
            {% if metadata_status.has_eidas %}
              <span class="a-badge a-badge-success">Attivo (indici 99/100 presenti)</span>
            {% else %}
              <span class="a-badge a-badge-neutral">Non attivo</span>
            {% endif %}
          </div>
        </div>
      {% else %}
        <div class="a-alert a-alert-danger" style="margin-top:8px;">
          <strong>Impossibile verificare lo stato del metadata locale:</strong> {{ metadata_status.error }}
        </div>
      {% endif %}
    {% else %}
      <div class="a-muted" style="font-size:12px;">Verifica in corso...</div>
    {% endif %}
  </div>
</div>

{# Registry sync + IdP table #}
<div class="a-card">
  <div class="a-card-header">
    <div>
      <div>Registry SPID</div>
      <div class="a-muted" style="font-size:11px;font-weight:400;">Lista locale sincronizzata giornalmente dal registry AgID.</div>
    </div>
    <div class="a-muted" style="font-size:12px;text-align:right;">
      <div>Ultima sync DB</div>
      <div class="a-mono">{{ last_sync_at.strftime('%d/%m/%Y %H:%M') if last_sync_at else '—' }}</div>
    </div>
  </div>
  {% if sync_status == 'ok' %}
  <div style="padding:8px 20px;border-bottom:1px solid var(--border-1);">
    <div class="a-alert a-alert-success" style="margin-bottom:0;">Sync completata. Nuovi IdP inseriti: {{ sync_inserted or '0' }}.</div>
  </div>
  {% elif sync_status == 'error' %}
  <div style="padding:8px 20px;border-bottom:1px solid var(--border-1);">
    <div class="a-alert a-alert-warning" style="margin-bottom:0;">Sync non riuscita ({{ sync_error or 'errore sconosciuto' }}).</div>
  </div>
  {% endif %}
  {% if idps %}
  <div class="a-table-wrap">
    <table class="a-table">
      <thead>
        <tr>
          <th>Logo</th>
          <th>Entity ID</th>
          <th>Organization</th>
          <th>Aggiornato</th>
          <th>Sync</th>
          <th>Abilitato</th>
          <th>Dettagli</th>
        </tr>
      </thead>
      <tbody>
        {% for item in idps %}
        <tr>
          <td style="width:72px;">
            {% if item.registry_logo_uri %}
            <img src="{{ item.registry_logo_uri }}" alt="{{ item.registry_organization_name or item.registry_entity_id }}" style="max-height:32px;max-width:64px;object-fit:contain;">
            {% else %}
            <span class="a-muted">—</span>
            {% endif %}
          </td>
          <td><code class="a-mono" style="font-size:11px;word-break:break-all;">{{ item.registry_entity_id or '—' }}</code></td>
          <td>{{ item.registry_organization_name or item.display_name or '—' }}</td>
          <td class="a-mono a-muted" style="font-size:11px;">{{ item.registry_lastupdate_date or '—' }}</td>
          <td class="a-mono a-muted" style="font-size:11px;">{{ item.registry_synced_at.strftime('%d/%m/%Y %H:%M') if item.registry_synced_at else '—' }}</td>
          <td>
            <form method="post" action="/admin/idps/{{ item.id }}/toggle" style="display:inline;">
              {% if item.enabled %}
              <button type="submit" class="a-btn a-btn-sm" style="background:var(--success-bg);color:var(--success);border:1px solid var(--success);" title="Clicca per disabilitare">✓ Sì</button>
              {% else %}
              <button type="submit" class="a-btn a-btn-neutral a-btn-sm" title="Clicca per abilitare">No</button>
              {% endif %}
            </form>
          </td>
          <td>
            <a class="a-btn a-btn-secondary a-btn-sm" href="/admin/idps/detail?entity_id={{ item.registry_entity_id | urlencode }}">Dettagli</a>
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% else %}
  <div class="a-card-body a-muted" style="font-size:13px;">Nessun IdP sincronizzato dal registry.</div>
  {% endif %}
</div>

<script>
function confirmRegenCert() {
  return window.confirm(
    "ATTENZIONE: La rigenerazione del certificato genererà una nuova chiave privata e un nuovo certificato di firma.\n\n" +
    "Questo invaliderà immediatamente il metadata SAML precedentemente registrato su AgID/FICEP e renderà impossibile l'autenticazione fino all'aggiornamento dei portali governativi.\n\n" +
    "Vuoi procedere?"
  );
}
</script>
{% endblock %}
