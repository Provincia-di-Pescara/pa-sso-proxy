{% extends "base.html.j2" %}
{% block title %}Configurazione CIE OIDC — PA SSO Proxy{% endblock %}
{% block page_title %}CIE OIDC{% endblock %}

{% block content %}
<form method="post" action="/admin/cie" style="max-width:720px;">
  <div class="a-card" style="margin-bottom:14px;">
    <div class="a-card-header">Configurazione base</div>
    <div class="a-card-body">
      <div class="a-form-group">
        <label class="a-label" for="saml_metadata_url">SAML Metadata URL</label>
        <input type="url" class="a-input" id="saml_metadata_url" name="saml_metadata_url"
               value="{{ config.saml_metadata_url if config else 'https://idserver.servizicie.interno.gov.it/idp/shibboleth?Metadata' }}">
      </div>

      {% if derived_client_id %}
      <div class="a-form-group">
        <label class="a-label">Client ID <span class="a-badge a-badge-neutral" style="text-transform:none;letter-spacing:0;">auto</span></label>
        <input type="text" class="a-input a-input-ro a-mono" value="{{ derived_client_id }}" readonly>
        <div class="a-form-hint">Derivato da PROXY_HOSTNAME. Da registrare nel portale federazione CIE.</div>
      </div>
      {% endif %}

      <div class="a-form-grid-2">
        <div class="a-form-group">
          <label class="a-label" for="jwk_federation_id">JWK Federation</label>
          <select class="a-select" id="jwk_federation_id" name="jwk_federation_id">
            <option value="">— nessuna —</option>
            {% for key in jwk_keys %}
            <option value="{{ key.id }}"
              {% if config and config.jwk_federation_id == key.id %}selected{% endif %}>
              {{ key.name }} ({{ key.use }})
            </option>
            {% endfor %}
          </select>
        </div>
        <div class="a-form-group">
          <label class="a-label" for="jwk_core_sig_id">JWK Core Signature</label>
          <select class="a-select" id="jwk_core_sig_id" name="jwk_core_sig_id">
            <option value="">— nessuna —</option>
            {% for key in jwk_keys %}
            <option value="{{ key.id }}"
              {% if config and config.jwk_core_sig_id == key.id %}selected{% endif %}>
              {{ key.name }} ({{ key.use }})
            </option>
            {% endfor %}
          </select>
        </div>
        <div class="a-form-group">
          <label class="a-label" for="jwk_core_enc_id">JWK Core Encryption</label>
          <select class="a-select" id="jwk_core_enc_id" name="jwk_core_enc_id">
            <option value="">— nessuna —</option>
            {% for key in jwk_keys %}
            <option value="{{ key.id }}"
              {% if config and config.jwk_core_enc_id == key.id %}selected{% endif %}>
              {{ key.name }} ({{ key.use }})
            </option>
            {% endfor %}
          </select>
        </div>
      </div>
    </div>
  </div>

  <div class="a-card" style="margin-bottom:14px;">
    <div class="a-card-header">OIDC Federation (CIE 1.0)</div>
    <div class="a-card-body">
      <div class="a-form-group" style="display:flex;align-items:center;gap:10px;">
        <label class="a-toggle">
          <input type="checkbox" id="oidc_federation_enabled" name="oidc_federation_enabled"
                 {% if config and config.oidc_federation_enabled %}checked{% endif %}>
          <span class="a-toggle-slider"></span>
        </label>
        <label for="oidc_federation_enabled" style="font-size:13px;color:var(--fg-2);cursor:pointer;">Abilita backend CIE OIDC Federation</label>
      </div>

      <div class="a-form-group">
        <label class="a-label" for="oidc_environment">Ambiente</label>
        <select class="a-select" id="oidc_environment" name="oidc_environment">
          <option value="">— seleziona —</option>
          <option value="collaudo"
            {% if config and config.oidc_environment == 'collaudo' %}selected{% endif %}>
            Pre-produzione (Collaudo)
          </option>
          <option value="produzione"
            {% if config and config.oidc_environment == 'produzione' %}selected{% endif %}>
            Produzione
          </option>
        </select>
        <div class="a-form-hint">Imposta automaticamente Provider URL, Trust Anchor e Authority Hint.</div>
        <div id="env-urls-preview" class="a-mono a-muted" style="font-size:11px;margin-top:6px;line-height:1.7;"></div>
      </div>

      <div class="a-form-grid-2">
        <div class="a-form-group">
          <label class="a-label">Homepage URI</label>
          <input type="text" class="a-input" name="homepage_uri"
                 value="{{ config.homepage_uri or '' if config else '' }}">
        </div>
        <div class="a-form-group">
          <label class="a-label">Policy URI</label>
          <input type="text" class="a-input" name="policy_uri"
                 value="{{ config.policy_uri or '' if config else '' }}">
        </div>
        <div class="a-form-group">
          <label class="a-label">Logo URI</label>
          <input type="text" class="a-input" name="logo_uri"
                 value="{{ config.logo_uri or '' if config else '' }}">
        </div>
        <div class="a-form-group">
          <label class="a-label">PEC ente <span style="font-weight:400;text-transform:none;font-size:11px;color:var(--fg-muted);">(richiesta dal portale CIE)</span></label>
          <input type="email" class="a-input" name="oidc_contact_email"
                 value="{{ config.oidc_contact_email or '' if config else '' }}">
        </div>
      </div>

      <div class="a-form-group" style="grid-column:1/-1;">
        <label class="a-label">
          Trust Mark (JWT)
          <span class="a-badge a-badge-neutral" style="text-transform:none;letter-spacing:0;margin-left:4px;">auto-fetch a startup</span>
        </label>
        <textarea class="a-textarea a-mono" name="trust_mark" rows="3"
                  placeholder="Recuperato automaticamente dal registry CIE.">{{ config.trust_mark or '' if config else '' }}</textarea>
        {% if config and config.trust_mark %}
        <div class="a-form-hint" style="color:var(--success);">Trust mark presente.</div>
        {% else %}
        <div class="a-form-hint" style="color:var(--warning);">Trust mark assente — verrà recuperato automaticamente al prossimo avvio se il Client ID è registrato nel portale CIE.</div>
        {% endif %}
      </div>
    </div>
  </div>

  <button type="submit" class="a-btn a-btn-primary">Salva configurazione</button>
</form>

<hr class="a-separator">

<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
  <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--fg-muted);">Chiavi JWK</div>
  <div style="display:flex;align-items:center;gap:12px;">
    {% if jwk_keys %}
    <span class="a-badge a-badge-success">{{ jwk_keys | length }} chiavi</span>
    {% if generated_at %}
    <span class="a-muted" style="font-size:12px;">Generate il <span class="a-mono">{{ generated_at.strftime('%Y-%m-%d %H:%M') }} UTC</span></span>
    {% endif %}
    {% endif %}
    <form method="post" action="/admin/cie/generate-all" style="display:inline;"
          onsubmit="return !{{ 'true' if jwk_keys else 'false' }} || confirm('Rigenera tutte le chiavi JWK?\n\nLe chiavi esistenti verranno eliminate. Dopo la rigenerazione dovrai aggiornare il portale federazione CIE con il nuovo JWKS.')">
      <button type="submit" class="a-btn a-btn-secondary a-btn-sm">
        {{ 'Rigenera chiavi' if jwk_keys else 'Genera chiavi' }}
      </button>
    </form>
  </div>
</div>

{% if jwk_keys %}
<div class="a-card">
  <div class="a-tabs" id="jwksTabs">
    <button class="a-tab active" data-tab="tab-portal" onclick="switchTab('tab-portal', this)">
      Portale CIE <span class="a-badge a-badge-warning" style="margin-left:4px;">incolla qui</span>
    </button>
    <button class="a-tab" data-tab="tab-satosa" onclick="switchTab('tab-satosa', this)">
      SATOSA interno
    </button>
  </div>
  <div id="tab-portal" class="a-tab-panel" style="padding:16px;">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
      <span class="a-muted" style="font-size:12px;">Chiave federation completa (kty/kid/e/n/d/p/q/dp/dq/qi) — incollare nel portale federazione CIE.</span>
      <button type="button" class="a-btn a-btn-neutral a-btn-sm" onclick="copyPortalJwks(event)">Copia</button>
    </div>
    <pre style="margin:0;font-size:11px;background:var(--bg-1);padding:12px;border-radius:4px;overflow-x:auto;"><code id="jwks-portal">{{ portal_jwks_json }}</code></pre>
  </div>
  <div id="tab-satosa" class="a-tab-panel" style="padding:16px;display:none;">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
      <span class="a-muted" style="font-size:12px;">Chiavi pubbliche con alg/use — esposte da SATOSA su /openid_relying_party/jwks.json.</span>
      <button type="button" class="a-btn a-btn-neutral a-btn-sm" onclick="copyPublicJwks(event)">Copia</button>
    </div>
    <pre style="margin:0;font-size:11px;background:var(--bg-1);padding:12px;border-radius:4px;overflow-x:auto;"><code id="jwks-public">{{ public_jwks_json }}</code></pre>
  </div>
</div>
{% else %}
<div class="a-muted" style="font-size:13px;">Nessuna chiave JWK generata.</div>
{% endif %}

<script>
  const CIE_ENVIRONMENTS = {{ environments | tojson }};

  function switchTab(tabId, btn) {
    document.querySelectorAll('.a-tab-panel').forEach(function(p) { p.style.display = 'none'; });
    document.querySelectorAll('#jwksTabs .a-tab').forEach(function(t) { t.classList.remove('active'); });
    document.getElementById(tabId).style.display = '';
    btn.classList.add('active');
  }

  function renderEnvUrls() {
    var sel = document.getElementById('oidc_environment');
    var preview = document.getElementById('env-urls-preview');
    if (!sel || !preview) return;
    var env = CIE_ENVIRONMENTS[sel.value];
    if (!env) { preview.textContent = ''; return; }
    preview.innerHTML =
      'Provider: ' + env.provider_url + '<br>' +
      'Trust Anchor: ' + env.trust_anchor_url + '<br>' +
      'Authority Hint: ' + env.authority_hint_url;
  }

  function _copyFromEl(elId, btn) {
    var el = document.getElementById(elId);
    if (!el || !btn) return;
    navigator.clipboard.writeText(el.textContent).then(function () {
      var prev = btn.textContent;
      btn.textContent = 'Copiato!';
      setTimeout(function () { btn.textContent = prev; }, 1500);
    });
  }
  function copyPortalJwks(event) {
    _copyFromEl('jwks-portal', event.target);
  }
  function copyPublicJwks(event) {
    _copyFromEl('jwks-public', event.target);
  }

  document.addEventListener('DOMContentLoaded', function () {
    var sel = document.getElementById('oidc_environment');
    if (sel) { sel.addEventListener('change', renderEnvUrls); renderEnvUrls(); }
  });
</script>
{% endblock %}
