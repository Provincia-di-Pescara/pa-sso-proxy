{% extends "base.html.j2" %}
{% block title %}Configurazione CIE OIDC — PA SSO Proxy{% endblock %}
{% block content %}
<h2>CIE OIDC</h2>

<form method="post" action="/admin/cie" class="mb-5">
  <h5 class="mt-3 mb-3">Configurazione</h5>
  <div class="mb-3">
    <label class="form-label" for="saml_metadata_url">SAML Metadata URL</label>
    <input type="url" class="form-control" id="saml_metadata_url" name="saml_metadata_url"
           value="{{ config.saml_metadata_url if config else 'https://idserver.servizicie.interno.gov.it/idp/shibboleth?Metadata' }}">
  </div>

  {% if derived_client_id %}
  <div class="mb-3">
    <label class="form-label">Client ID <span class="badge bg-secondary">auto</span></label>
    <input type="text" class="form-control font-monospace" value="{{ derived_client_id }}" readonly>
    <div class="form-text">Derivato da PROXY_HOSTNAME. Da registrare nel portale federazione CIE.</div>
  </div>
  {% endif %}

  <div class="mb-3">
    <label class="form-label" for="jwk_federation_id">JWK Federation</label>
    <select class="form-select" id="jwk_federation_id" name="jwk_federation_id">
      <option value="">— nessuna —</option>
      {% for key in jwk_keys %}
      <option value="{{ key.id }}"
        {% if config and config.jwk_federation_id == key.id %}selected{% endif %}>
        {{ key.name }} ({{ key.use }})
      </option>
      {% endfor %}
    </select>
  </div>
  <div class="mb-3">
    <label class="form-label" for="jwk_core_sig_id">JWK Core Signature</label>
    <select class="form-select" id="jwk_core_sig_id" name="jwk_core_sig_id">
      <option value="">— nessuna —</option>
      {% for key in jwk_keys %}
      <option value="{{ key.id }}"
        {% if config and config.jwk_core_sig_id == key.id %}selected{% endif %}>
        {{ key.name }} ({{ key.use }})
      </option>
      {% endfor %}
    </select>
  </div>
  <div class="mb-3">
    <label class="form-label" for="jwk_core_enc_id">JWK Core Encryption</label>
    <select class="form-select" id="jwk_core_enc_id" name="jwk_core_enc_id">
      <option value="">— nessuna —</option>
      {% for key in jwk_keys %}
      <option value="{{ key.id }}"
        {% if config and config.jwk_core_enc_id == key.id %}selected{% endif %}>
        {{ key.name }} ({{ key.use }})
      </option>
      {% endfor %}
    </select>
  </div>
  <div class="card mt-4">
    <div class="card-header">
      <h5 class="mb-0">OIDC Federation (CIE 1.0)</h5>
    </div>
    <div class="card-body">
      <div class="form-check form-switch mb-3">
        <input class="form-check-input" type="checkbox" role="switch"
               id="oidc_federation_enabled" name="oidc_federation_enabled"
               {% if config and config.oidc_federation_enabled %}checked{% endif %}>
        <label class="form-check-label" for="oidc_federation_enabled">Abilita backend CIE OIDC Federation</label>
      </div>

      <div class="row g-3">
        <div class="col-md-12">
          <label class="form-label" for="oidc_environment">Ambiente</label>
          <select class="form-select" id="oidc_environment" name="oidc_environment">
            <option value="">— seleziona —</option>
            <option value="collaudo"
              {% if config and config.oidc_environment == 'collaudo' %}selected{% endif %}>
              Pre-produzione (Collaudo)
            </option>
            <option value="produzione"
              {% if config and config.oidc_environment == 'produzione' %}selected{% endif %}>
              Produzione
            </option>
          </select>
          <div class="form-text">
            Imposta automaticamente Provider URL, Trust Anchor e Authority Hint.
          </div>
          <div id="env-urls-preview" class="small text-muted mt-2 font-monospace"></div>
        </div>
        <div class="col-md-4">
          <label class="form-label">Homepage URI</label>
          <input type="text" class="form-control" name="homepage_uri"
                 value="{{ config.homepage_uri or '' if config else '' }}">
        </div>
        <div class="col-md-4">
          <label class="form-label">Policy URI</label>
          <input type="text" class="form-control" name="policy_uri"
                 value="{{ config.policy_uri or '' if config else '' }}">
        </div>
        <div class="col-md-4">
          <label class="form-label">Logo URI</label>
          <input type="text" class="form-control" name="logo_uri"
                 value="{{ config.logo_uri or '' if config else '' }}">
        </div>
        <div class="col-md-12">
          <label class="form-label">
            Trust Mark (JWT)
            <span class="badge bg-secondary">auto-fetch a startup</span>
          </label>
          <textarea class="form-control font-monospace" name="trust_mark" rows="3"
                    placeholder="Recuperato automaticamente dal registry CIE. Inserire manualmente solo se il fetch fallisce.">{{ config.trust_mark or '' if config else '' }}</textarea>
          {% if config and config.trust_mark %}
          <div class="form-text text-success">Trust mark presente.</div>
          {% else %}
          <div class="form-text text-warning">Trust mark assente — verrà recuperato automaticamente al prossimo avvio se il Client ID è registrato nel portale CIE.</div>
          {% endif %}
        </div>
        <div class="col-md-6">
          <label class="form-label">Contatto email OIDC</label>
          <input type="email" class="form-control" name="oidc_contact_email"
                 value="{{ config.oidc_contact_email or '' if config else '' }}">
        </div>
      </div>
    </div>
  </div>

  <button type="submit" class="btn btn-primary mt-3">Salva configurazione</button>
</form>

<hr>

<h5 class="mt-4 mb-3">Chiavi JWK</h5>

<div class="mb-3 d-flex gap-2">
  <form method="post" action="/admin/cie/generate-jwk/federation" class="d-inline">
    <button type="submit" class="btn btn-outline-secondary btn-sm">+ Genera Federation</button>
  </form>
  <form method="post" action="/admin/cie/generate-jwk/sig" class="d-inline">
    <button type="submit" class="btn btn-outline-secondary btn-sm">+ Genera Sig</button>
  </form>
  <form method="post" action="/admin/cie/generate-jwk/enc" class="d-inline">
    <button type="submit" class="btn btn-outline-secondary btn-sm">+ Genera Enc</button>
  </form>
</div>

{% if jwk_keys %}
<ul class="nav nav-tabs mb-0" id="jwksTabs">
  <li class="nav-item">
    <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-portal">
      Portale CIE <span class="badge bg-warning text-dark ms-1">incolla qui</span>
    </button>
  </li>
  <li class="nav-item">
    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-satosa">
      SATOSA interno
    </button>
  </li>
</ul>
<div class="tab-content border border-top-0 rounded-bottom mb-4">
  <div class="tab-pane fade show active p-3" id="tab-portal">
    <div class="d-flex justify-content-between align-items-center mb-2">
      <small class="text-muted">Chiavi complete (kty/kid/e/n/d/p/q/dp/dq/qi) — formato accettato dal portale federazione CIE.</small>
      <button type="button" class="btn btn-sm btn-outline-warning" onclick="copyPortalJwks()">Copia</button>
    </div>
    <pre class="mb-0 small"><code id="jwks-portal">{{ portal_jwks_json }}</code></pre>
  </div>
  <div class="tab-pane fade p-3" id="tab-satosa">
    <div class="d-flex justify-content-between align-items-center mb-2">
      <small class="text-muted">Chiavi pubbliche con alg/use — esposte da SATOSA su /openid_relying_party/jwks.json.</small>
      <button type="button" class="btn btn-sm btn-outline-primary" onclick="copyPublicJwks()">Copia</button>
    </div>
    <pre class="mb-0 small"><code id="jwks-public">{{ public_jwks_json }}</code></pre>
  </div>
</div>

<table class="table table-sm table-hover">
  <thead>
    <tr>
      <th>Name</th>
      <th>Use</th>
      <th>Kid</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    {% for key in jwk_keys %}
    <tr>
      <td>{{ key.name }}</td>
      <td><code>{{ key.use }}</code></td>
      <td><small><code>{{ key.public_jwk.get('kid', '—') if key.public_jwk else '—' }}</code></small></td>
      <td>
        <form method="post" action="/admin/cie/delete-jwk/{{ key.id }}" class="d-inline"
              onsubmit="return confirm('Eliminare la chiave {{ key.name }}?')">
          <button type="submit" class="btn btn-sm btn-outline-danger">Elimina</button>
        </form>
      </td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% else %}
<p class="text-muted">Nessuna chiave JWK configurata.</p>
{% endif %}

<script>
  const CIE_ENVIRONMENTS = {{ environments | tojson }};

  function renderEnvUrls() {
    const sel = document.getElementById('oidc_environment');
    const preview = document.getElementById('env-urls-preview');
    if (!sel || !preview) return;
    const env = CIE_ENVIRONMENTS[sel.value];
    if (!env) { preview.textContent = ''; return; }
    preview.innerHTML =
      'Provider: ' + env.provider_url + '<br>' +
      'Trust Anchor: ' + env.trust_anchor_url + '<br>' +
      'Authority Hint: ' + env.authority_hint_url;
  }

  function _copyFromEl(elId, btn) {
    const el = document.getElementById(elId);
    if (!el || !btn) return;
    navigator.clipboard.writeText(el.textContent).then(function () {
      const prev = btn.textContent;
      btn.textContent = 'Copiato!';
      setTimeout(function () { btn.textContent = prev; }, 1500);
    });
  }
  function copyPortalJwks() {
    _copyFromEl('jwks-portal', event.target);
  }
  function copyPublicJwks() {
    _copyFromEl('jwks-public', event.target);
  }

  document.addEventListener('DOMContentLoaded', function () {
    const sel = document.getElementById('oidc_environment');
    if (sel) { sel.addEventListener('change', renderEnvUrls); renderEnvUrls(); }
  });
</script>
{% endblock %}
