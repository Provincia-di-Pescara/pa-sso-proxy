{% extends "base.html.j2" %}
{% block title %}Risultato autenticazione — PA SSO Proxy{% endblock %}
{% block content %}

{% if success %}
<div class="alert alert-success d-flex align-items-center mb-4">
  <span class="fs-4 me-2">✓</span>
  <strong>Autenticazione completata con successo</strong>
</div>

<h4>UserInfo <small class="text-muted fs-6">(risposta /userinfo)</small></h4>
<pre class="bg-light p-3 rounded border" style="font-size:13px">{{ userinfo }}</pre>

<h4 class="mt-4">ID Token Claims <small class="text-muted fs-6">(JWT decodificato)</small></h4>
<pre class="bg-light p-3 rounded border" style="font-size:13px">{{ claims }}</pre>

<h4 class="mt-4">Token Response <small class="text-muted fs-6">(senza id_token)</small></h4>
<pre class="bg-light p-3 rounded border" style="font-size:13px">{{ token_response }}</pre>

<details class="mt-3">
  <summary class="text-muted small" style="cursor:pointer">ID Token JWT (raw)</summary>
  <pre class="bg-light p-3 rounded border mt-2" style="font-size:11px; word-break:break-all; white-space:pre-wrap">{{ id_token }}</pre>
</details>

{% else %}
<div class="alert alert-danger d-flex align-items-center mb-4">
  <span class="fs-4 me-2">✗</span>
  <div>
    <strong>Errore: {{ error }}</strong>
    {% if error_description %}<br><span class="small">{{ error_description }}</span>{% endif %}
  </div>
</div>

{% if raw %}
<h4>Risposta raw</h4>
<pre class="bg-light p-3 rounded border" style="font-size:13px">{{ raw }}</pre>
{% endif %}
{% endif %}

<div class="mt-4 d-flex flex-wrap gap-2">
  <a href="/admin/test-client" class="btn btn-outline-secondary">← Torna al test client</a>
  {% if success %}
  <a href="/admin/test-client/start" class="btn btn-success">▶ Nuova autenticazione</a>
  {% if logout_url %}
  <a href="{{ logout_url }}" class="btn btn-outline-danger">⏻ Logout (OIDC end_session)</a>
  {% endif %}
  {% endif %}
</div>
{% endblock %}
