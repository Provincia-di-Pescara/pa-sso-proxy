{% extends "base.html.j2" %}
{% block title %}Risultato autenticazione — PA SSO Proxy{% endblock %}
{% block page_title %}Risultato autenticazione{% endblock %}

{% block content %}
<div style="max-width:860px;">
  {% if success %}
  <div class="a-alert a-alert-success" style="margin-bottom:20px;">
    ✓ <strong>Autenticazione completata con successo</strong>
  </div>

  <div class="a-card" style="margin-bottom:14px;">
    <div class="a-card-header">UserInfo <span class="a-muted" style="font-weight:400;font-size:11px;">(risposta /userinfo)</span></div>
    <div class="a-card-body" style="padding:0;">
      <pre style="margin:0;padding:16px;font-size:12px;font-family:var(--font-mono);background:var(--bg-1);border-radius:0 0 8px 8px;overflow-x:auto;">{{ userinfo }}</pre>
    </div>
  </div>

  <div class="a-card" style="margin-bottom:14px;">
    <div class="a-card-header">ID Token Claims <span class="a-muted" style="font-weight:400;font-size:11px;">(JWT decodificato)</span></div>
    <div class="a-card-body" style="padding:0;">
      <pre style="margin:0;padding:16px;font-size:12px;font-family:var(--font-mono);background:var(--bg-1);border-radius:0 0 8px 8px;overflow-x:auto;">{{ claims }}</pre>
    </div>
  </div>

  <div class="a-card" style="margin-bottom:14px;">
    <div class="a-card-header">Token Response <span class="a-muted" style="font-weight:400;font-size:11px;">(senza id_token)</span></div>
    <div class="a-card-body" style="padding:0;">
      <pre style="margin:0;padding:16px;font-size:12px;font-family:var(--font-mono);background:var(--bg-1);border-radius:0 0 8px 8px;overflow-x:auto;">{{ token_response }}</pre>
    </div>
  </div>

  <details style="margin-bottom:14px;">
    <summary class="a-muted" style="cursor:pointer;font-size:13px;">ID Token JWT (raw)</summary>
    <pre style="margin-top:8px;padding:16px;font-size:11px;font-family:var(--font-mono);background:var(--bg-1);border:1px solid var(--border-1);border-radius:4px;word-break:break-all;white-space:pre-wrap;">{{ id_token }}</pre>
  </details>

  {% else %}
  <div class="a-alert a-alert-danger" style="margin-bottom:20px;">
    ✗ <strong>Errore: {{ error }}</strong>
    {% if error_description %}<br><span style="font-size:12px;">{{ error_description }}</span>{% endif %}
  </div>

  {% if raw %}
  <div class="a-card">
    <div class="a-card-header">Risposta raw</div>
    <div class="a-card-body" style="padding:0;">
      <pre style="margin:0;padding:16px;font-size:12px;font-family:var(--font-mono);background:var(--bg-1);border-radius:0 0 8px 8px;overflow-x:auto;">{{ raw }}</pre>
    </div>
  </div>
  {% endif %}
  {% endif %}

  <div style="display:flex;flex-wrap:wrap;gap:8px;margin-top:20px;">
    <a href="/admin/test-client" class="a-btn a-btn-secondary">← Torna al test client</a>
    {% if success %}
    <a href="/admin/test-client/start" class="a-btn a-btn-primary">▶ Nuova autenticazione</a>
    {% if logout_url %}
    <a href="{{ logout_url }}" class="a-btn a-btn-danger">⏻ Logout (OIDC end_session)</a>
    {% endif %}
    {% endif %}
  </div>
</div>
{% endblock %}
