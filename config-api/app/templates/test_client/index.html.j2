{% extends "base.html.j2" %}
{% block title %}Test Client OIDC — PA SSO Proxy{% endblock %}
{% block page_title %}Test Client OIDC{% endblock %}
{% block page_subtitle %}<div class="a-topbar-sub">Testa il flusso OIDC PKCE end-to-end senza uscire dall'admin</div>{% endblock %}

{% block content %}
{% if not client or not has_secret %}
<div class="a-card" style="max-width:560px;border-color:var(--warning);">
  <div class="a-card-header">Setup necessario</div>
  <div class="a-card-body">
    <p style="font-size:13px;margin-bottom:12px;">Il client di test non è ancora configurato. Clicca il pulsante per crearlo automaticamente.</p>
    <div class="a-muted" style="font-size:12px;margin-bottom:12px;">
      Verrà creato un client OIDC dedicato (<code class="a-mono">{{ test_client_id }}</code>) con redirect URI:<br>
      <code class="a-mono">{{ callback_uri }}</code>
    </div>
    <div class="a-muted" style="font-size:12px;margin-bottom:16px;">
      Dopo la creazione, SATOSA si ricarica automaticamente (~5 secondi). Attendi prima di avviare il test.
    </div>
    <form method="post" action="/admin/test-client/setup">
      <button type="submit" class="a-btn a-btn-primary">
        {% if client %}Rigenera secret{% else %}Crea client di test{% endif %}
      </button>
    </form>
  </div>
</div>
{% else %}
<div class="a-card" style="max-width:560px;border-color:var(--success);margin-bottom:16px;">
  <div class="a-card-header">
    Client configurato
    <span class="a-badge a-badge-success">pronto</span>
  </div>
  <div class="a-card-body">
    <table class="a-table" style="margin-bottom:16px;">
      <tr><td style="font-weight:600;width:130px;padding:6px 12px;">Client ID</td><td style="padding:6px 12px;"><code class="a-mono">{{ test_client_id }}</code></td></tr>
      <tr><td style="font-weight:600;padding:6px 12px;">Redirect URI</td><td style="padding:6px 12px;"><code class="a-mono">{{ callback_uri }}</code></td></tr>
      <tr><td style="font-weight:600;padding:6px 12px;">Scopes</td><td style="padding:6px 12px;"><code class="a-mono">openid profile email</code></td></tr>
      <tr><td style="font-weight:600;padding:6px 12px;">PKCE</td><td style="padding:6px 12px;">S256 ✓</td></tr>
    </table>
    <form method="get" action="/admin/test-client/start" style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
      <div style="display:flex;gap:12px;">
        {% for lvl, label in [('1','Minimo'), ('2','Standard'), ('3','Massimo')] %}
        <label style="display:flex;align-items:center;gap:6px;cursor:pointer;font-size:13px;">
          <input type="radio" name="level" value="{{ lvl }}" {% if lvl == '2' %}checked{% endif %}>
          <strong>L{{ lvl }}</strong> <span class="a-muted">{{ label }}</span>
        </label>
        {% endfor %}
      </div>
      <button type="submit" class="a-btn a-btn-primary">▶ Avvia autenticazione SPID / CIE</button>
    </form>
    <div style="margin-top:12px;">
      <form method="post" action="/admin/test-client/setup" style="display:inline;">
        <button type="submit" class="a-btn a-btn-neutral a-btn-sm">Rigenera secret</button>
      </form>
    </div>
  </div>
</div>
<div class="a-alert a-alert-info">
  <strong>Come funziona:</strong> cliccando "Avvia" verrai reindirizzato alla pagina di scelta provider (SPID/CIE).
  Dopo l'autenticazione, tornerai qui con i claims dell'utente.
  <br>In ambiente di test locale i provider SPID reali non sono raggiungibili — puoi comunque verificare la discovery page e il flusso OIDC fino al redirect verso l'IdP.
</div>
{% endif %}
{% endblock %}
