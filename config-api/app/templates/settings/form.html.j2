{% extends "base.html.j2" %}
{% block title %}Impostazioni Ente — PA SSO Proxy{% endblock %}
{% block page_title %}Impostazioni Ente{% endblock %}

{% block content %}
<div style="max-width:640px;">
  {% if error %}
  <div class="a-alert a-alert-danger">{{ error }}</div>
  {% endif %}
  {% if saved %}
  <div class="a-alert a-alert-success">Impostazioni salvate.</div>
  {% endif %}

  <form method="post" action="/admin/settings">
    <div class="a-card" style="margin-bottom:14px;">
      <div class="a-card-header">Dati ente</div>
      <div class="a-card-body">
        <div class="a-form-group">
          <label for="org_display_name" class="a-label">Nome visualizzato ente</label>
          <input type="text" class="a-input" id="org_display_name" name="org_display_name"
                 value="{{ s.org_display_name if s else '' }}">
        </div>
        <div class="a-form-group">
          <label for="org_name" class="a-label">Nome ente (slug IPA) <span style="color:var(--danger);">*</span></label>
          <input type="text" class="a-input" id="org_name" name="org_name" required
                 value="{{ s.org_name if s else '' }}">
        </div>
        <div class="a-form-group">
          <label for="org_url" class="a-label">URL ente</label>
          <input type="url" class="a-input" id="org_url" name="org_url"
                 value="{{ s.org_url if s else '' }}">
        </div>
        <div class="a-form-group">
          <label for="proxy_hostname" class="a-label">Hostname proxy SSO <span style="color:var(--danger);">*</span></label>
          <input type="text" class="a-input" id="proxy_hostname" name="proxy_hostname" required
                 value="{{ s.proxy_hostname if s else '' }}">
        </div>
        <div class="a-form-grid-2">
          <div class="a-form-group">
            <label for="ipa_code" class="a-label">Codice IPA <span style="color:var(--danger);">*</span></label>
            <input type="text" class="a-input" id="ipa_code" name="ipa_code" required
                   value="{{ s.ipa_code if s else '' }}">
          </div>
          <div class="a-form-group">
            <label for="vat_number" class="a-label">Partita IVA ente <span style="color:var(--danger);">*</span></label>
            <input type="text" class="a-input" id="vat_number" name="vat_number" required
                   value="{{ s.vat_number if s else '' }}">
            <div class="a-form-hint">Usata nel tag <code>spid:FiscalCode</code> del metadata SPID.</div>
          </div>
        </div>
        <div class="a-form-grid-2">
          <div class="a-form-group">
            <label for="contact_email" class="a-label">Email contatto tecnico</label>
            <input type="email" class="a-input" id="contact_email" name="contact_email"
                   value="{{ s.contact_email if s else '' }}">
          </div>
          <div class="a-form-group">
            <label for="contact_phone" class="a-label">Telefono contatto tecnico</label>
            <input type="text" class="a-input" id="contact_phone" name="contact_phone"
                   value="{{ s.contact_phone if s else '' }}">
          </div>
        </div>
        <div class="a-form-group">
          <label for="org_city" class="a-label">Città sede ente <span style="color:var(--danger);">*</span></label>
          <input type="text" class="a-input" id="org_city" name="org_city" required
                 value="{{ s.org_city if s else '' }}">
        </div>
      </div>
    </div>

    <div class="a-card" style="margin-bottom:14px;">
      <div class="a-card-header">Pagina di accesso (Discovery)</div>
      <div class="a-card-body">
        <div class="a-form-group">
          <label for="logo_url" class="a-label">URL logo ente</label>
          <input type="url" class="a-input" id="logo_url" name="logo_url"
                 value="{{ s.logo_url if s else '' }}">
          <div class="a-form-hint">Mostrato in alto nella pagina di accesso al posto del crest SVG.</div>
        </div>
        <div class="a-form-group">
          <label for="favicon_url" class="a-label">URL favicon</label>
          <input type="url" class="a-input" id="favicon_url" name="favicon_url"
                 value="{{ s.favicon_url if s else '' }}">
          <div class="a-form-hint">Icona mostrata nella tab del browser. Formati: ICO, PNG, SVG.</div>
        </div>
        <div class="a-form-grid-2">
          <div class="a-form-group">
            <label for="privacy_url" class="a-label">URL Privacy</label>
            <input type="url" class="a-input" id="privacy_url" name="privacy_url"
                   value="{{ s.privacy_url if s else '' }}">
          </div>
          <div class="a-form-group">
            <label for="legal_notes_url" class="a-label">URL Note legali</label>
            <input type="url" class="a-input" id="legal_notes_url" name="legal_notes_url"
                   value="{{ s.legal_notes_url if s else '' }}">
          </div>
          <div class="a-form-group">
            <label for="accessibility_url" class="a-label">URL Accessibilità</label>
            <input type="url" class="a-input" id="accessibility_url" name="accessibility_url"
                   value="{{ s.accessibility_url if s else '' }}">
          </div>
          <div class="a-form-group">
            <label for="support_url" class="a-label">URL Assistenza</label>
            <input type="url" class="a-input" id="support_url" name="support_url"
                   value="{{ s.support_url if s else '' }}">
          </div>
        </div>
      </div>
    </div>

    <button type="submit" class="a-btn a-btn-primary">Salva</button>
  </form>

  {# ── eIDAS ─────────────────────────────────────────────────────────────── #}
  {% if saved or request.query_params.get('eidas_saved') %}
  <div class="a-alert a-alert-success" style="margin-top:16px;">Configurazione eIDAS aggiornata. SATOSA ricaricato.</div>
  {% endif %}

  <div class="a-card" style="margin-top:16px;">
    <div class="a-card-header">
      Integrazione eIDAS
      {% if s and s.eidas_enabled %}
      <span class="a-badge a-badge-success">abilitato</span>
      {% else %}
      <span class="a-badge a-badge-neutral">disabilitato</span>
      {% endif %}
    </div>
    <div class="a-card-body">
      <p style="font-size:13px;margin-bottom:12px;color:var(--fg-muted);">
        Permette l'autenticazione di cittadini UE tramite il Nodo eIDAS Italiano (AgID).<br>
        <strong>Attenzione:</strong> l'attivazione modifica il metadata SPID (aggiunge ACS index 99/100)
        e richiede di ripetere la validazione presso AgID.
      </p>
      {% if s and s.eidas_enabled %}
      <div style="margin-bottom:12px;">
        Ambiente attivo: <span class="a-badge a-badge-neutral">{{ s.eidas_environment or 'prod' }}</span>
      </div>
      <form method="post" action="/admin/settings/eidas">
        <input type="hidden" name="action" value="disable">
        <input type="hidden" name="confirmed" value="yes">
        <button type="submit" class="a-btn a-btn-danger a-btn-sm">Disabilita eIDAS</button>
      </form>
      {% else %}
      <form method="post" action="/admin/settings/eidas" id="eidas-form">
        <input type="hidden" name="action" value="enable">
        <input type="hidden" name="confirmed" id="eidas-confirmed" value="">
        <div class="a-form-group" style="margin-bottom:12px;">
          <label class="a-label">Ambiente</label>
          <select name="environment" id="eidas-env" class="a-select" style="width:auto;">
            <option value="prod">Produzione</option>
            <option value="qa">QA (collaudo)</option>
          </select>
        </div>
        <button type="button" class="a-btn a-btn-primary a-btn-sm" onclick="confirmEidas()">Abilita eIDAS</button>
      </form>
      {% endif %}
    </div>
  </div>
</div>

<script>
function confirmEidas() {
  var env = document.getElementById("eidas-env").value;
  var envLabel = env === "qa" ? "QA (collaudo)" : "Produzione";
  var ok = window.confirm(
    "Attenzione: abilitare eIDAS modifica il metadata SPID.\n\n" +
    "Ambiente selezionato: " + envLabel + "\n\n" +
    "Sarà necessario:\n" +
    "  • Re-inviare il metadata SPID ad AgID\n" +
    "  • Ripetere la validazione SPID\n\n" +
    "Continuare?"
  );
  if (ok) {
    document.getElementById("eidas-confirmed").value = "yes";
    document.getElementById("eidas-form").submit();
  }
}
</script>
{% endblock %}
