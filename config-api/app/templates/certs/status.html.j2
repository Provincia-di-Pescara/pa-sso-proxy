{% extends "base.html.j2" %}
{% block title %}Certificato SPID — PA SSO Proxy{% endblock %}
{% block page_title %}Certificato SPID{% endblock %}

{% block content %}
<div style="max-width:640px;">
  {% if error %}<div class="a-alert a-alert-danger">{{ error }}</div>{% endif %}

  {% if cert %}
    {% set days_left = (cert.not_valid_after - now).days %}
    {% if days_left < 90 %}
    <div class="a-alert a-alert-warning">
      Il certificato scade tra <strong>{{ days_left }} giorni</strong> ({{ cert.not_valid_after.strftime('%Y-%m-%d') }}). Rigenera il certificato.
    </div>
    {% else %}
    <div class="a-alert a-alert-success">
      Certificato valido fino al <strong>{{ cert.not_valid_after.strftime('%Y-%m-%d') }}</strong> ({{ days_left }} giorni rimanenti).
    </div>
    {% endif %}

    <div class="a-card" style="margin-top:16px;">
      <div class="a-card-body">
        <div class="a-form-group">
          <label class="a-label">Subject DN</label>
          <input class="a-input a-input-ro" type="text" value="{{ cert.subject_dn }}" readonly>
        </div>
        <div style="font-size:12px;color:var(--fg-muted);">Generato il: <span class="a-mono">{{ cert.created_at.strftime('%Y-%m-%d %H:%M') }}</span></div>
      </div>
    </div>
  {% else %}
  <div class="a-alert a-alert-warning">Nessun certificato SPID configurato. Configura le impostazioni ente e genera il certificato.</div>
  {% endif %}

  <form method="post" action="/admin/certs/generate" style="margin-top:20px;">
    <button type="submit" class="a-btn a-btn-primary">
      {% if cert %}Rigenera certificato{% else %}Genera certificato{% endif %}
    </button>
  </form>
</div>
{% endblock %}
