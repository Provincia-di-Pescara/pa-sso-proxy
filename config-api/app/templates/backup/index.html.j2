{% extends "base.html.j2" %}
{% block title %}Backup & Ripristino — PA SSO Proxy{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="h4 mb-0">Backup &amp; Ripristino</h2>
</div>

{% if msg %}
<div class="alert alert-success alert-dismissible fade show" role="alert">
  <strong>✅</strong> {{ msg }}
  <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
{% endif %}

{% if err %}
<div class="alert alert-danger alert-dismissible fade show" role="alert">
  <strong>❌</strong> {{ err }}
  <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
{% endif %}

<div class="row g-4">

  {# ---- EXPORT ---- #}
  <div class="col-md-6">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <h5 class="card-title">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor"
               class="bi bi-download me-1 text-primary" viewBox="0 0 16 16">
            <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5"/>
            <path d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708z"/>
          </svg>
          Esporta backup
        </h5>
        <p class="card-text text-muted small mb-3">
          Scarica un file JSON con tutta la configurazione attuale: impostazioni ente,
          client OIDC, provider SPID (inclusi i metadata XML scaricati), configurazione
          CIE OIDC, chiavi JWK e certificato SPID.
        </p>
        <div class="alert alert-warning py-2 small mb-3">
          <strong>⚠️ Attenzione:</strong> il file contiene chiavi private. Conservalo in modo sicuro e non condividerlo.
        </div>
        <a href="/admin/backup/export" class="btn btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor"
               class="bi bi-download me-1" viewBox="0 0 16 16">
            <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5"/>
            <path d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708z"/>
          </svg>
          Scarica backup
        </a>
      </div>
    </div>
  </div>

  {# ---- IMPORT ---- #}
  <div class="col-md-6">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <h5 class="card-title">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor"
               class="bi bi-upload me-1 text-danger" viewBox="0 0 16 16">
            <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5"/>
            <path d="M7.646 1.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1-.708.708L8.5 2.707V11.5a.5.5 0 0 1-1 0V2.707L5.354 4.854a.5.5 0 1 1-.708-.708z"/>
          </svg>
          Ripristina da backup
        </h5>
        <p class="card-text text-muted small mb-3">
          Carica un file di backup precedentemente esportato. Tutti i dati attuali
          verranno <strong>sostituiti</strong> con quelli del backup. La configurazione
          SATOSA verrà rigenerata automaticamente.
        </p>
        <div class="alert alert-danger py-2 small mb-3">
          <strong>🔴 Operazione distruttiva:</strong> il ripristino sovrascrive
          completamente la configurazione corrente. Assicurati di avere un backup aggiornato.
        </div>
        <form method="post" action="/admin/backup/import"
              enctype="multipart/form-data"
              onsubmit="return confirm('Sei sicuro? Tutti i dati correnti saranno sostituiti.');">
          <div class="mb-3">
            <label for="file" class="form-label fw-semibold">File di backup (.json)</label>
            <input type="file" class="form-control form-control-sm" id="file" name="file"
                   accept="application/json,.json" required>
          </div>
          <button type="submit" class="btn btn-danger">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor"
                 class="bi bi-upload me-1" viewBox="0 0 16 16">
              <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5"/>
              <path d="M7.646 1.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1-.708.708L8.5 2.707V11.5a.5.5 0 0 1-1 0V2.707L5.354 4.854a.5.5 0 1 1-.708-.708z"/>
            </svg>
            Ripristina
          </button>
        </form>
      </div>
    </div>
  </div>

</div>

{# ---- cosa include il backup ---- #}
<div class="card border-0 shadow-sm mt-4">
  <div class="card-body">
    <h6 class="card-title text-muted text-uppercase" style="font-size:.75rem; letter-spacing:.05em;">Contenuto del backup</h6>
    <div class="row g-2 small">
      <div class="col-sm-4">
        <ul class="mb-0 ps-3">
          <li>Impostazioni ente</li>
          <li>Client OIDC (con secret)</li>
        </ul>
      </div>
      <div class="col-sm-4">
        <ul class="mb-0 ps-3">
          <li>Provider SPID + metadata XML</li>
          <li>Configurazione CIE OIDC Federation</li>
        </ul>
      </div>
      <div class="col-sm-4">
        <ul class="mb-0 ps-3">
          <li>Chiavi JWK (federation, sig, enc)</li>
          <li>Certificato SPID (cert + chiave privata)</li>
        </ul>
      </div>
    </div>
  </div>
</div>
{% endblock %}
