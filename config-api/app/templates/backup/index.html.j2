{% extends "base.html.j2" %}
{% block title %}Backup &amp; Ripristino — PA SSO Proxy{% endblock %}
{% block page_title %}Backup &amp; Ripristino{% endblock %}

{% block content %}
{% if msg %}
<div class="a-alert a-alert-success" style="margin-bottom:16px;">
  ✅ {{ msg }}
</div>
{% endif %}

{% if err %}
<div class="a-alert a-alert-danger" style="margin-bottom:16px;">
  ❌ {{ err }}
</div>
{% endif %}

<div class="a-grid-2" style="margin-bottom:20px;">

  {# EXPORT #}
  <div class="a-card">
    <div class="a-card-header">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      Esporta backup
    </div>
    <div class="a-card-body">
      <p style="font-size:13px;color:var(--fg-muted);margin-bottom:12px;">Scarica un file JSON con tutta la configurazione attuale: impostazioni ente, client OIDC, provider SPID (inclusi i metadata XML scaricati), configurazione CIE OIDC, chiavi JWK e certificato SPID.</p>
      <div class="a-alert a-alert-warning" style="font-size:12px;margin-bottom:12px;">
        <strong>⚠️ Attenzione:</strong> il file contiene chiavi private. Conservalo in modo sicuro e non condividerlo.
      </div>
      <a href="/admin/backup/export" class="a-btn a-btn-primary a-btn-sm">Scarica backup</a>
    </div>
  </div>

  {# IMPORT #}
  <div class="a-card">
    <div class="a-card-header">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
      Ripristina da backup
    </div>
    <div class="a-card-body">
      <p style="font-size:13px;color:var(--fg-muted);margin-bottom:12px;">Carica un file di backup precedentemente esportato. Tutti i dati attuali verranno <strong>sostituiti</strong> con quelli del backup. La configurazione SATOSA verrà rigenerata automaticamente.</p>
      <div class="a-alert a-alert-danger" style="font-size:12px;margin-bottom:12px;">
        <strong>🔴 Operazione distruttiva:</strong> il ripristino sovrascrive completamente la configurazione corrente.
      </div>
      <form method="post" action="/admin/backup/import"
            enctype="multipart/form-data"
            onsubmit="return confirm('Sei sicuro? Tutti i dati correnti saranno sostituiti.');">
        <div class="a-form-group">
          <label class="a-label" for="file">File di backup (.json)</label>
          <input type="file" class="a-input" id="file" name="file"
                 accept="application/json,.json" required style="padding:6px 12px;">
        </div>
        <button type="submit" class="a-btn a-btn-danger a-btn-sm">Ripristina</button>
      </form>
    </div>
  </div>

</div>

<div class="a-card">
  <div class="a-card-header">Contenuto del backup</div>
  <div class="a-card-body" style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px;font-size:13px;">
    <ul style="margin:0;padding-left:20px;">
      <li>Impostazioni ente</li>
      <li>Client OIDC (con secret)</li>
    </ul>
    <ul style="margin:0;padding-left:20px;">
      <li>Provider SPID + metadata XML</li>
      <li>Configurazione CIE OIDC Federation</li>
    </ul>
    <ul style="margin:0;padding-left:20px;">
      <li>Chiavi JWK (federation, sig, enc)</li>
      <li>Certificato SPID (cert + chiave privata)</li>
    </ul>
  </div>
</div>
{% endblock %}
