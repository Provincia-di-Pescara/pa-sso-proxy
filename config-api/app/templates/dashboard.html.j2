{% extends "base.html.j2" %}
{% block title %}Dashboard — PA SSO Proxy{% endblock %}
{% block content %}
<div class="d-flex justify-content-between align-items-center mb-3">
  <h2 class="d-flex align-items-center">
    Dashboard
    <span class="badge bg-secondary ms-2 fs-6" style="font-weight: normal; opacity: 0.85;">{{ app_version }}</span>
  </h2>
  {% if settings and settings.proxy_hostname %}
  <small class="text-muted">{{ settings.proxy_hostname }}</small>
  {% else %}
  <small class="text-warning">⚠ Impostazioni ente non configurate</small>
  {% endif %}
</div>

{# ── Riga 1: Stato sistema ───────────────────────────────────────────────── #}
<div class="row g-3">

  <div class="col-md-3">
    <div class="card h-100 {% if satosa_status == 'running' %}border-success{% elif satosa_status == 'unavailable' %}border-secondary{% else %}border-warning{% endif %}">
      <div class="card-body">
        <h6 class="card-subtitle mb-1 text-muted">SATOSA</h6>
        <p class="card-text fs-5">
          {% if satosa_status == 'running' %}
            <span class="badge bg-success">running</span>
          {% elif satosa_status == 'unavailable' %}
            <span class="badge bg-secondary">unavailable</span>
          {% else %}
            <span class="badge bg-warning text-dark">{{ satosa_status }}</span>
          {% endif %}
        </p>
      </div>
    </div>
  </div>

  <div class="col-md-3">
    <div class="card h-100">
      <div class="card-body">
        <h6 class="card-subtitle mb-1 text-muted">Clienti OIDC</h6>
        <p class="card-text fs-3 fw-bold">{{ clients_enabled }}<small class="fs-6 text-muted"> / {{ clients_total }}</small></p>
        <p class="card-text"><small class="text-muted">abilitati / totali</small></p>
        <a href="/admin/clients" class="btn btn-sm btn-outline-primary">Gestisci</a>
      </div>
    </div>
  </div>

  <div class="col-md-3">
    <div class="card h-100">
      <div class="card-body">
        <h6 class="card-subtitle mb-1 text-muted">Provider SPID</h6>
        <p class="card-text fs-3 fw-bold">{{ idps_enabled }}<small class="fs-6 text-muted"> / {{ idps_total }}</small></p>
        <p class="card-text"><small class="text-muted">abilitati / totali</small></p>
        <a href="/admin/idps" class="btn btn-sm btn-outline-primary">Gestisci</a>
      </div>
    </div>
  </div>

  <div class="col-md-3">
    <div class="card h-100 {% if cert_days is not none and cert_days < 90 %}border-warning{% elif cert_days is not none %}border-success{% else %}border-secondary{% endif %}">
      <div class="card-body">
        <h6 class="card-subtitle mb-1 text-muted">Certificato SPID</h6>
        {% if cert %}
          {% if cert_days < 30 %}
            <p class="card-text text-danger fw-bold">Scade in {{ cert_days }} giorni</p>
          {% elif cert_days < 90 %}
            <p class="card-text text-warning">Scade in {{ cert_days }} giorni</p>
          {% else %}
            <p class="card-text text-success">Valido ({{ cert_days }} giorni)</p>
          {% endif %}
          <p class="card-text"><small class="text-muted">{{ cert.not_valid_after.strftime('%Y-%m-%d') }}</small></p>
        {% else %}
          <p class="card-text text-warning">Non configurato</p>
        {% endif %}
        <a href="/admin/certs" class="btn btn-sm btn-outline-primary">Dettagli</a>
      </div>
    </div>
  </div>

</div>

{# ── Riga 2: Statistiche accessi ─────────────────────────────────────────── #}
<h5 class="mt-4 mb-2 text-muted" style="font-size:.85rem; text-transform:uppercase; letter-spacing:.05em;">Monitoraggio Accessi</h5>

{% if access and access.has_data %}

<div class="row g-3 mb-3">
  <div class="col-md-4">
    <div class="card h-100">
      <div class="card-body">
        <h6 class="card-subtitle mb-1 text-muted">Oggi</h6>
        <p class="card-text fs-3 fw-bold">{{ access.today.total }}</p>
        <p class="card-text">
          <span class="badge bg-success">{{ access.today.success }} ok</span>
          {% if access.today.failure > 0 %}<span class="badge bg-warning text-dark ms-1">{{ access.today.failure }} falliti</span>{% endif %}
        </p>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card h-100">
      <div class="card-body">
        <h6 class="card-subtitle mb-1 text-muted">Ultimi 7 giorni</h6>
        <p class="card-text fs-3 fw-bold">{{ access.week.total }}</p>
        <p class="card-text">
          <span class="badge bg-success">{{ access.week.success }} ok</span>
          {% if access.week.failure > 0 %}<span class="badge bg-warning text-dark ms-1">{{ access.week.failure }} falliti</span>{% endif %}
        </p>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card h-100">
      <div class="card-body">
        <h6 class="card-subtitle mb-1 text-muted">Ultimi 30 giorni</h6>
        <p class="card-text fs-3 fw-bold">{{ access.month.total }}</p>
        <p class="card-text">
          <span class="badge bg-success">{{ access.month.success }} ok</span>
          {% if access.month.failure > 0 %}<span class="badge bg-warning text-dark ms-1">{{ access.month.failure }} falliti</span>{% endif %}
        </p>
      </div>
    </div>
  </div>
</div>

<div class="row g-3 mb-3">
  <div class="col-md-6">
    <div class="card h-100">
      <div class="card-body">
        <h6 class="card-subtitle mb-2 text-muted">Per provider (30 giorni)</h6>
        <table class="table table-sm mb-0">
          <thead><tr><th>Provider</th><th class="text-end">OK</th><th class="text-end">KO</th><th class="text-end">Tot.</th></tr></thead>
          <tbody>
            {% for pt, s in access.by_provider.items() %}
            <tr>
              <td>
                {% if pt == 'spid' %}<span class="badge bg-primary">SPID</span>
                {% elif pt == 'cie' %}<span class="badge bg-info text-dark">CIE</span>
                {% elif pt == 'eidas' %}<span class="badge bg-secondary">eIDAS</span>
                {% elif pt == 'itwallet' %}<span class="badge bg-dark">IT Wallet</span>
                {% else %}<span class="badge bg-light text-dark">{{ pt }}</span>
                {% endif %}
              </td>
              <td class="text-end text-success">{{ s.success }}</td>
              <td class="text-end text-warning">{{ s.failure }}</td>
              <td class="text-end">{{ s.success + s.failure }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card h-100">
      <div class="card-body">
        <h6 class="card-subtitle mb-2 text-muted">Per client OIDC (30 giorni)</h6>
        <table class="table table-sm mb-0">
          <thead><tr><th>Client</th><th class="text-end">Totale</th><th>Tasso OK</th></tr></thead>
          <tbody>
            {% for cid, s in access.by_client.items() %}
            {% set pct = ((s.success / s.total) * 100) | round | int if s.total > 0 else 0 %}
            <tr>
              <td><small>{{ client_name_map.get(cid, cid) }}</small></td>
              <td class="text-end">{{ s.total }}</td>
              <td style="width:120px;">
                <div class="d-flex align-items-center gap-2">
                  <div class="progress flex-grow-1" style="height:5px;">
                    <div class="progress-bar {% if pct >= 90 %}bg-success{% elif pct >= 70 %}bg-warning{% else %}bg-danger{% endif %}"
                         style="width:{{ pct }}%"></div>
                  </div>
                  <small class="text-muted">{{ pct }}%</small>
                </div>
              </td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

{# ── Riga 3: Attività recente ─────────────────────────────────────────────── #}
<div class="card mb-3">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-center mb-2">
      <h6 class="card-subtitle text-muted">Attività recente</h6>
      <a href="/admin/access-log" class="btn btn-sm btn-outline-secondary">Tutti i log</a>
    </div>
    {% if access.recent %}
    <div class="table-responsive">
      <table class="table table-sm mb-0">
        <thead><tr><th>Timestamp</th><th>Provider</th><th>Client</th><th>Esito</th><th>Errore</th></tr></thead>
        <tbody>
          {% for log in access.recent %}
          <tr>
            <td><small class="text-muted font-monospace">{{ log.timestamp.strftime('%m-%d %H:%M:%S') if log.timestamp else '—' }}</small></td>
            <td>
              {% if log.provider_type == 'spid' %}<span class="badge bg-primary">SPID</span>
              {% elif log.provider_type == 'cie' %}<span class="badge bg-info text-dark">CIE</span>
              {% else %}<span class="badge bg-secondary">{{ log.provider_type }}</span>
              {% endif %}
            </td>
            <td><small>{{ client_name_map.get(log.client_id, log.client_id) or '—' }}</small></td>
            <td>
              {% if log.result == 'success' %}<span class="badge bg-success">OK</span>
              {% elif log.result == 'failure' %}<span class="badge bg-warning text-dark">KO</span>
              {% else %}<span class="badge bg-danger">Err</span>
              {% endif %}
            </td>
            <td><small class="text-muted">{{ log.error_code or '—' }}</small></td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    {% else %}
    <p class="text-muted mb-0 small">Nessun accesso recente.</p>
    {% endif %}
  </div>
</div>

{% else %}
<div class="card mb-3 border-secondary">
  <div class="card-body text-center py-4">
    <p class="text-muted mb-1">Nessun dato di accesso disponibile.</p>
    <p class="text-muted small mb-0">Il plugin di monitoraggio SATOSA non è ancora attivo oppure non ci sono ancora accessi registrati.
      <a href="/admin/access-log">Vai al Monitoraggio</a></p>
  </div>
</div>
{% endif %}

{# ── Riga 4: CIE Federation ──────────────────────────────────────────────── #}
{% if cie_config and cie_config.oidc_federation_enabled %}
<div class="row g-3 mt-1">
  <div class="col-md-12">
    <div class="card {% if cie_config.trust_mark %}border-success{% else %}border-warning{% endif %}">
      <div class="card-body">
        <h6 class="card-subtitle mb-2 text-muted">CIE OIDC Federation</h6>
        <div class="d-flex gap-4 flex-wrap align-items-start">
          <div>
            <small class="text-muted d-block">Trust Mark</small>
            {% if cie_config.trust_mark %}
              <span class="badge bg-success">presente</span>
            {% else %}
              <span class="badge bg-warning text-dark">assente</span>
              <small class="text-muted d-block">verrà recuperato al prossimo riavvio config-api</small>
            {% endif %}
          </div>
          <div>
            <small class="text-muted d-block">Ambiente</small>
            <span class="badge bg-secondary">{{ cie_config.oidc_environment or '—' }}</span>
          </div>
          {% if cie_oidc_client_id %}
          <div>
            <small class="text-muted d-block">Client ID (Entity ID)</small>
            <code class="small">{{ cie_oidc_client_id }}</code>
          </div>
          {% endif %}
          <div>
            <small class="text-muted d-block">Entity Configuration</small>
            <a href="{{ cie_oidc_client_id | replace('/CieOidcRp', '') }}/.well-known/openid-federation" target="_blank" class="small">
              /.well-known/openid-federation ↗
            </a>
          </div>
        </div>
        <a href="/admin/cie" class="btn btn-sm btn-outline-primary mt-2">Configura</a>
      </div>
    </div>
  </div>
</div>
{% endif %}
{% endblock %}
