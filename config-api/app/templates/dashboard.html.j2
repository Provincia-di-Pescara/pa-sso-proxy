{% extends "base.html.j2" %}
{% block title %}Dashboard — PA SSO Proxy{% endblock %}
{% block content %}
<div class="d-flex justify-content-between align-items-center mb-3">
  <h2 class="d-flex align-items-center">
    Dashboard
    <span class="badge bg-secondary ms-2 fs-6" style="font-weight: normal; opacity: 0.85;">{{ app_version }}</span>
  </h2>
  {% if settings and settings.proxy_hostname %}
  <small class="text-muted">{{ settings.proxy_hostname }}</small>
  {% else %}
  <small class="text-warning">⚠ Impostazioni ente non configurate</small>
  {% endif %}
</div>

<div class="row g-3">

  <div class="col-md-3">
    <div class="card h-100 {% if satosa_status == 'running' %}border-success{% elif satosa_status == 'unavailable' %}border-secondary{% else %}border-warning{% endif %}">
      <div class="card-body">
        <h6 class="card-subtitle mb-1 text-muted">SATOSA</h6>
        <p class="card-text fs-5">
          {% if satosa_status == 'running' %}
            <span class="badge bg-success">running</span>
          {% elif satosa_status == 'unavailable' %}
            <span class="badge bg-secondary">unavailable</span>
          {% else %}
            <span class="badge bg-warning text-dark">{{ satosa_status }}</span>
          {% endif %}
        </p>
      </div>
    </div>
  </div>

  <div class="col-md-3">
    <div class="card h-100">
      <div class="card-body">
        <h6 class="card-subtitle mb-1 text-muted">Clienti OIDC</h6>
        <p class="card-text fs-3 fw-bold">{{ clients_enabled }}<small class="fs-6 text-muted"> / {{ clients_total }}</small></p>
        <p class="card-text"><small class="text-muted">abilitati / totali</small></p>
        <a href="/admin/clients" class="btn btn-sm btn-outline-primary">Gestisci</a>
      </div>
    </div>
  </div>

  <div class="col-md-3">
    <div class="card h-100">
      <div class="card-body">
        <h6 class="card-subtitle mb-1 text-muted">Provider SPID</h6>
        <p class="card-text fs-3 fw-bold">{{ idps_enabled }}<small class="fs-6 text-muted"> / {{ idps_total }}</small></p>
        <p class="card-text"><small class="text-muted">abilitati / totali</small></p>
        <a href="/admin/idps" class="btn btn-sm btn-outline-primary">Gestisci</a>
      </div>
    </div>
  </div>

  <div class="col-md-3">
    <div class="card h-100 {% if cert_days is not none and cert_days < 90 %}border-warning{% elif cert_days is not none %}border-success{% else %}border-secondary{% endif %}">
      <div class="card-body">
        <h6 class="card-subtitle mb-1 text-muted">Certificato SPID</h6>
        {% if cert %}
          {% if cert_days < 30 %}
            <p class="card-text text-danger fw-bold">Scade in {{ cert_days }} giorni</p>
          {% elif cert_days < 90 %}
            <p class="card-text text-warning">Scade in {{ cert_days }} giorni</p>
          {% else %}
            <p class="card-text text-success">Valido ({{ cert_days }} giorni)</p>
          {% endif %}
          <p class="card-text"><small class="text-muted">{{ cert.not_valid_after.strftime('%Y-%m-%d') }}</small></p>
        {% else %}
          <p class="card-text text-warning">Non configurato</p>
        {% endif %}
        <a href="/admin/certs" class="btn btn-sm btn-outline-primary">Dettagli</a>
      </div>
    </div>
  </div>

</div>

{% if cie_config and cie_config.oidc_federation_enabled %}
<div class="row g-3 mt-1">
  <div class="col-md-12">
    <div class="card {% if cie_config.trust_mark %}border-success{% else %}border-warning{% endif %}">
      <div class="card-body">
        <h6 class="card-subtitle mb-2 text-muted">CIE OIDC Federation</h6>
        <div class="d-flex gap-4 flex-wrap align-items-start">
          <div>
            <small class="text-muted d-block">Trust Mark</small>
            {% if cie_config.trust_mark %}
              <span class="badge bg-success">presente</span>
            {% else %}
              <span class="badge bg-warning text-dark">assente</span>
              <small class="text-muted d-block">verrà recuperato al prossimo riavvio config-api</small>
            {% endif %}
          </div>
          <div>
            <small class="text-muted d-block">Ambiente</small>
            <span class="badge bg-secondary">{{ cie_config.oidc_environment or '—' }}</span>
          </div>
          {% if cie_oidc_client_id %}
          <div>
            <small class="text-muted d-block">Client ID (Entity ID)</small>
            <code class="small">{{ cie_oidc_client_id }}</code>
          </div>
          {% endif %}
          <div>
            <small class="text-muted d-block">Entity Configuration</small>
            <a href="{{ cie_oidc_client_id | replace('/CieOidcRp', '') }}/.well-known/openid-federation" target="_blank" class="small">
              /.well-known/openid-federation ↗
            </a>
          </div>
        </div>
        <a href="/admin/cie" class="btn btn-sm btn-outline-primary mt-2">Configura</a>
      </div>
    </div>
  </div>
</div>
{% endif %}
{% endblock %}
