{% extends "base.html.j2" %}
{% block title %}Dashboard — PA SSO Proxy{% endblock %}

{% block page_title %}Dashboard{% endblock %}

{% block page_subtitle %}
{% if settings and settings.proxy_hostname %}
<div class="a-topbar-sub">{{ settings.proxy_hostname }}</div>
{% else %}
<div class="a-topbar-sub" style="color: var(--warning);">⚠ Impostazioni ente non configurate</div>
{% endif %}
{% endblock %}

{% block topbar_actions %}
{% if satosa_status == 'running' %}
<div class="a-status-pill ok"><span class="a-status-dot"></span> SATOSA running</div>
{% elif satosa_status == 'unavailable' %}
<div class="a-status-pill err"><span class="a-status-dot"></span> SATOSA unavailable</div>
{% else %}
<div class="a-status-pill err"><span class="a-status-dot"></span> SATOSA {{ satosa_status }}</div>
{% endif %}
{% endblock %}

{% block content %}

{# ── Sezione 1: Stato sistema ────────────────────────────────────────────── #}
<div class="a-stat-grid" style="margin-bottom: 24px;">

  <div class="a-stat">
    <div class="a-stat-label">SATOSA</div>
    {% if satosa_status == 'running' %}
    <div><span class="a-badge a-badge-success">running</span></div>
    {% elif satosa_status == 'unavailable' %}
    <div><span class="a-badge a-badge-neutral">unavailable</span></div>
    {% else %}
    <div><span class="a-badge a-badge-warning">{{ satosa_status }}</span></div>
    {% endif %}
  </div>

  <div class="a-stat">
    <div class="a-stat-label">Clienti OIDC</div>
    <div class="a-stat-value">{{ clients_enabled }}<span style="font-size:16px;font-weight:400;color:var(--fg-muted);"> / {{ clients_total }}</span></div>
    <div class="a-stat-footer">abilitati / totali · <a href="/admin/clients" style="color:var(--brand);font-size:12px;">Gestisci →</a></div>
  </div>

  <div class="a-stat">
    <div class="a-stat-label">Provider SPID</div>
    <div class="a-stat-value">{{ idps_enabled }}<span style="font-size:16px;font-weight:400;color:var(--fg-muted);"> / {{ idps_total }}</span></div>
    <div class="a-stat-footer">abilitati / totali · <a href="/admin/idps" style="color:var(--brand);font-size:12px;">Gestisci →</a></div>
  </div>

  <div class="a-stat">
    <div class="a-stat-label">Certificato SPID</div>
    {% if cert %}
      {% if cert_days < 30 %}
      <span class="a-badge a-badge-danger">Scade in {{ cert_days }} giorni</span>
      {% elif cert_days < 90 %}
      <span class="a-badge a-badge-warning">Scade in {{ cert_days }} giorni</span>
      {% else %}
      <span class="a-badge a-badge-success">Valido · {{ cert_days }}gg</span>
      {% endif %}
      <div class="a-stat-footer">{{ cert.not_valid_after.strftime('%Y-%m-%d') }} · <a href="/admin/certs" style="color:var(--brand);font-size:12px;">Dettagli →</a></div>
    {% else %}
    <div><span class="a-badge a-badge-warning">Non configurato</span></div>
    <div class="a-stat-footer"><a href="/admin/certs" style="color:var(--brand);font-size:12px;">Configura →</a></div>
    {% endif %}
  </div>

</div>

{# ── Sezione 2: Monitoraggio accessi ─────────────────────────────────────── #}
<div class="a-section-label">Monitoraggio Accessi</div>

{% if access and access.has_data %}

<div class="a-stat-grid-3" style="margin-bottom:14px;">
  <div class="a-stat">
    <div class="a-stat-label">Oggi</div>
    <div class="a-stat-value">{{ access.today.total }}</div>
    <div class="a-stat-footer">
      <span class="a-badge a-badge-success">{{ access.today.success }} ok</span>
      {% if access.today.failure > 0 %}<span class="a-badge a-badge-warning" style="margin-left:4px;">{{ access.today.failure }} falliti</span>{% endif %}
    </div>
  </div>
  <div class="a-stat">
    <div class="a-stat-label">Ultimi 7 giorni</div>
    <div class="a-stat-value">{{ access.week.total }}</div>
    <div class="a-stat-footer">
      <span class="a-badge a-badge-success">{{ access.week.success }} ok</span>
      {% if access.week.failure > 0 %}<span class="a-badge a-badge-warning" style="margin-left:4px;">{{ access.week.failure }} falliti</span>{% endif %}
    </div>
  </div>
  <div class="a-stat">
    <div class="a-stat-label">Ultimi 30 giorni</div>
    <div class="a-stat-value">{{ access.month.total }}</div>
    <div class="a-stat-footer">
      <span class="a-badge a-badge-success">{{ access.month.success }} ok</span>
      {% if access.month.failure > 0 %}<span class="a-badge a-badge-warning" style="margin-left:4px;">{{ access.month.failure }} falliti</span>{% endif %}
    </div>
  </div>
</div>

<div class="a-grid-2" style="margin-bottom:14px;">
  <div class="a-card">
    <div class="a-card-header">Per provider (30 giorni)</div>
    <div class="a-table-wrap">
      <table class="a-table">
        <thead><tr><th>Provider</th><th style="text-align:right">OK</th><th style="text-align:right">KO</th><th style="text-align:right">Tot.</th></tr></thead>
        <tbody>
          {% for pt, s in access.by_provider.items() %}
          <tr>
            <td>
              {% if pt == 'spid' %}<span class="a-badge-spid">SPID</span>
              {% elif pt == 'cie' %}<span class="a-badge-cie">CIE</span>
              {% else %}<span class="a-badge a-badge-neutral">{{ pt }}</span>
              {% endif %}
            </td>
            <td style="text-align:right;color:var(--success);">{{ s.success }}</td>
            <td style="text-align:right;color:var(--warning);">{{ s.failure }}</td>
            <td style="text-align:right;">{{ s.success + s.failure }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>

  <div class="a-card">
    <div class="a-card-header">Per client OIDC (30 giorni)</div>
    <div class="a-table-wrap">
      <table class="a-table">
        <thead><tr><th>Client</th><th style="text-align:right">Totale</th><th>Tasso OK</th></tr></thead>
        <tbody>
          {% for cid, s in access.by_client.items() %}
          {% set pct = ((s.success / s.total) * 100) | round | int if s.total > 0 else 0 %}
          <tr>
            <td class="a-mono">{{ client_name_map.get(cid, cid) }}</td>
            <td style="text-align:right;">{{ s.total }}</td>
            <td style="width:120px;">
              <div style="display:flex;align-items:center;gap:8px;">
                <div class="a-progress" style="flex:1;height:4px;">
                  <div class="a-progress-bar {% if pct >= 90 %}a-progress-bar-ok{% elif pct >= 70 %}a-progress-bar-warn{% else %}a-progress-bar-err{% endif %}" style="width:{{ pct }}%;"></div>
                </div>
                <span class="a-muted" style="font-size:11px;">{{ pct }}%</span>
              </div>
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</div>

{% if access.by_idp %}
<div class="a-card" style="margin-bottom:14px;">
  <div class="a-card-header">Per IdP (30 giorni)</div>
  <div class="a-table-wrap">
    <table class="a-table">
      <thead><tr><th>Identity Provider</th><th style="text-align:right">Accessi</th></tr></thead>
      <tbody>
        {% for idp, cnt in access.by_idp.items() %}
        <tr>
          <td class="a-mono" style="font-size:12px;">
            <a href="/admin/access-log?idp_entity_id={{ idp }}" style="color:inherit;">{{ idp | replace('https://', '') }}</a>
          </td>
          <td style="text-align:right;">{{ cnt }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>
{% endif %}

<div class="a-card" style="margin-bottom:14px;">
  <div class="a-card-header">
    Attività recente
    <a href="/admin/access-log" class="a-btn a-btn-secondary a-btn-sm">Tutti i log</a>
  </div>
  {% if access.recent %}
  <div class="a-table-wrap">
    <table class="a-table">
      <thead>
        <tr>
          <th>Timestamp</th><th>Provider</th><th>IdP</th><th>Client</th><th>Tipo</th><th>Esito</th><th>Errore</th>
        </tr>
      </thead>
      <tbody>
        {% for log in access.recent %}
        <tr>
          <td class="a-mono a-muted">{{ (log.timestamp | to_italian_time).strftime('%m-%d %H:%M:%S') if log.timestamp else '—' }}</td>
          <td>
            {% if log.provider_type == 'spid' %}<span class="a-badge-spid">SPID</span>
            {% elif log.provider_type == 'cie' %}<span class="a-badge-cie">CIE</span>
            {% else %}<span class="a-badge a-badge-neutral">{{ log.provider_type }}</span>
            {% endif %}
          </td>
          <td class="a-mono a-muted" style="font-size:11px;max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="{{ log.idp_entity_id or '' }}">
            {{ (log.idp_entity_id or '—') | replace('https://', '') }}
          </td>
          <td class="a-mono">{{ client_name_map.get(log.client_id, log.client_id) or '—' }}</td>
          <td>
            {% if log.user_type == 'PF' %}<span class="a-badge a-badge-neutral">Fisica</span>
            {% elif log.user_type == 'PG' %}<span class="a-badge a-badge-neutral">Giuridica</span>
            {% else %}—
            {% endif %}
          </td>
          <td>
            {% if log.result == 'success' %}<span class="a-badge a-badge-success">OK</span>
            {% elif log.result == 'failure' %}<span class="a-badge a-badge-warning">KO</span>
            {% else %}<span class="a-badge a-badge-danger">Err</span>
            {% endif %}
          </td>
          <td class="a-mono a-muted">{{ log.error_code or '—' }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% else %}
  <div class="a-card-body a-muted" style="font-size:13px;">Nessun accesso recente.</div>
  {% endif %}
</div>

{% else %}
<div class="a-card" style="text-align:center;padding:32px 20px;">
  <div class="a-muted" style="margin-bottom:4px;">Nessun dato di accesso disponibile.</div>
  <div class="a-muted" style="font-size:12px;">Il plugin di monitoraggio SATOSA non è ancora attivo oppure non ci sono ancora accessi registrati.
    <a href="/admin/access-log">Vai al Monitoraggio</a></div>
</div>
{% endif %}

{# ── Sezione 3: CIE Federation ───────────────────────────────────────────── #}
{% if cie_config and cie_config.oidc_federation_enabled %}
<div class="a-card" style="margin-top:14px;">
  <div class="a-card-header">
    CIE OIDC Federation
    {% if cie_config.trust_mark %}
    <span class="a-badge a-badge-success">trust mark presente</span>
    {% else %}
    <span class="a-badge a-badge-warning">trust mark assente</span>
    {% endif %}
  </div>
  <div class="a-card-body" style="display:flex;gap:32px;flex-wrap:wrap;align-items:flex-start;">
    <div>
      <div style="font-size:11px;color:var(--fg-muted);margin-bottom:3px;">Ambiente</div>
      <span class="a-badge a-badge-neutral">{{ cie_config.oidc_environment or '—' }}</span>
    </div>
    {% if cie_oidc_client_id %}
    <div>
      <div style="font-size:11px;color:var(--fg-muted);margin-bottom:3px;">Client ID (Entity ID)</div>
      <code class="a-mono">{{ cie_oidc_client_id }}</code>
    </div>
    <div>
      <div style="font-size:11px;color:var(--fg-muted);margin-bottom:3px;">Entity Configuration</div>
      <a href="{{ cie_oidc_client_id | replace('/CieOidcRp', '') }}/.well-known/openid-federation" target="_blank" style="font-size:13px;">
        /.well-known/openid-federation ↗
      </a>
    </div>
    {% endif %}
    {% if not cie_config.trust_mark %}
    <div style="font-size:12px;color:var(--fg-muted);">verrà recuperato al prossimo riavvio config-api</div>
    {% endif %}
  </div>
  <div style="padding:12px 20px;border-top:1px solid var(--border-1);">
    <a href="/admin/cie" class="a-btn a-btn-secondary a-btn-sm">Configura CIE</a>
  </div>
</div>
{% endif %}

{% endblock %}
