<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block title %}PA SSO Proxy{% endblock %}</title>
  <link rel="stylesheet" href="/admin/static/css/admin.css">
  {% if s and s.favicon_url %}<link rel="icon" href="{{ s.favicon_url }}">{% endif %}
</head>
<body>
<div class="a-shell">
  <!-- Sidebar 256px dark navy -->
  <nav class="a-sidebar">
    <div class="a-sidebar-header">
      {% if s and s.logo_url %}
      <img src="{{ s.logo_url }}" alt="Logo ente" style="height:36px;max-width:72px;object-fit:contain;">
      {% else %}
      <svg width="30" height="36" viewBox="0 0 30 36" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M15 0L0 6V18C0 26.4 6.6 34.2 15 36C23.4 34.2 30 26.4 30 18V6L15 0Z" fill="rgba(255,255,255,0.12)" stroke="rgba(255,255,255,0.2)" stroke-width="1"/>
        <path d="M15 4L3 9V18C3 24.9 8.4 31.2 15 33C21.6 31.2 27 24.9 27 18V9L15 4Z" fill="rgba(255,255,255,0.06)"/>
      </svg>
      {% endif %}
      <div>
        <div class="a-sidebar-title">PA SSO Proxy</div>
        <div class="a-sidebar-sub">
          {% if app_version %}v{{ app_version }}{% endif %}
          {% if s and s.org_display_name %} · {{ s.org_display_name }}{% endif %}
        </div>
      </div>
    </div>

    <div class="a-nav-group">Generale</div>
    <a href="/admin/" class="a-nav-item {% if request.url.path == '/admin/' %}active{% endif %}">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
      Dashboard
    </a>
    <a href="/admin/access-log" class="a-nav-item {% if request.url.path == '/admin/access-log' %}active{% endif %}">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
      Monitoraggio
    </a>
    <a href="/admin/access-log/advanced" class="a-nav-item {% if request.url.path.startswith('/admin/access-log/advanced') %}active{% endif %}">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      Log Accessi
    </a>

    <div class="a-nav-group">Provider di Identità</div>
    <a href="/admin/idps" class="a-nav-item {% if request.url.path.startswith('/admin/idps') or request.url.path.startswith('/admin/certs') %}active{% endif %}">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="9" y1="7" x2="15" y2="7"/><line x1="9" y1="11" x2="15" y2="11"/><line x1="9" y1="15" x2="13" y2="15"/></svg>
      SPID
    </a>
    <a href="/admin/cie" class="a-nav-item {% if request.url.path.startswith('/admin/cie') %}active{% endif %}">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
      CIE OIDC
    </a>
    <a href="/admin/eidas" class="a-nav-item {% if request.url.path.startswith('/admin/eidas') %}active{% endif %}">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
      eIDAS
    </a>
    <a href="/admin/itwallet" class="a-nav-item disabled" aria-disabled="true" tabindex="-1">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/></svg>
      IT Wallet
      <span class="a-nav-soon">soon</span>
    </a>

    <div class="a-nav-group">Applicazioni</div>
    <a href="/admin/clients" class="a-nav-item {% if request.url.path.startswith('/admin/clients') %}active{% endif %}">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
      Clienti OIDC
    </a>

    <div class="a-nav-group">Configurazione</div>
    <a href="/admin/settings" class="a-nav-item {% if request.url.path.startswith('/admin/settings') %}active{% endif %}">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
      Impostazioni
    </a>

    <div class="a-nav-group">Strumenti</div>
    <a href="/admin/test-client" class="a-nav-item {% if request.url.path.startswith('/admin/test-client') %}active{% endif %}">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
      Test Auth
    </a>
    <a href="/admin/backup" class="a-nav-item {% if request.url.path.startswith('/admin/backup') %}active{% endif %}">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="21 15 21 19 3 19 3 15"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
      Backup &amp; Ripristino
    </a>

    <!-- Logout at bottom -->
    <div style="margin-top: auto; padding: 16px;">
      <form method="post" action="/admin/logout">
        <button type="submit" class="a-btn a-btn-neutral a-btn-sm" style="width:100%; justify-content:center;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
          Logout
        </button>
      </form>
    </div>
  </nav>

  <!-- Main area -->
  <div class="a-main">
    <div class="a-topbar">
      <div style="flex:1; min-width:0;">
        <div class="a-topbar-title">{% block page_title %}{% endblock %}</div>
        {% block page_subtitle %}{% endblock %}
      </div>
      {% block topbar_actions %}{% endblock %}
    </div>
    <div class="a-content">
      <div class="a-content-inner">
        {% block content %}{% endblock %}
      </div>
    </div>
  </div>
</div>
</body>
</html>
