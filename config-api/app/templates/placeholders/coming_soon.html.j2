{% extends "base.html.j2" %}
{% block title %}{{ title }} — PA SSO Proxy{% endblock %}
{% block page_title %}{{ title }}{% endblock %}

{% block content %}
<div style="max-width:560px;">
  <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px;">
    <span class="a-badge a-badge-neutral">Prossimamente</span>
  </div>
  <div class="a-card">
    <div class="a-card-body">
      <p style="font-size:13px;color:var(--fg-muted);margin-bottom:8px;">{{ description }}</p>
      <p style="font-size:12px;color:var(--fg-muted);margin:0;">Questa funzionalità sarà disponibile in una versione futura del proxy.</p>
    </div>
  </div>
</div>
{% endblock %}
